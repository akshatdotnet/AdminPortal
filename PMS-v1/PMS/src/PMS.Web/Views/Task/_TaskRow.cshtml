@model IEnumerable<PMS.Application.DTOs.Task.ProjectTaskDto>
@using TaskStatus   = PMS.Domain.Enums.TaskStatus
@using TaskPriority = PMS.Domain.Enums.TaskPriority

@if (!Model.Any())
{
    <div class="text-center py-4 text-muted">
        <i class="bi bi-inbox me-2"></i>No tasks for this project yet.
        <a asp-controller="Task"
           asp-action="Index"
           asp-route-projectId="@@0"
           class="ms-2 btn btn-sm btn-outline-primary">
            Add Task
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Title</th>
                    <th style="width:110px">Status</th>
                    <th style="width:100px">Priority</th>
                    <th style="width:120px">Assigned To</th>
                    <th style="width:110px">Due Date</th>
                    <th style="width:80px">Hours</th>
                    <th style="width:80px" class="text-end pe-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model)
                {
                    var statusClass = task.Status switch
                    {
                        TaskStatus.Pending    => "badge bg-warning text-dark",
                        TaskStatus.InProgress => "badge bg-info",
                        TaskStatus.Completed  => "badge bg-success",
                        TaskStatus.OnHold     => "badge bg-secondary",
                        TaskStatus.Cancelled  => "badge bg-danger",
                        _                     => "badge bg-light text-dark"
                    };
                    var priorityClass = task.Priority switch
                    {
                        TaskPriority.Critical => "badge bg-danger",
                        TaskPriority.High     => "badge bg-warning text-dark",
                        TaskPriority.Medium   => "badge bg-info",
                        TaskPriority.Low      => "badge bg-secondary",
                        _                     => "badge bg-light text-dark"
                    };
                    <tr>
                        <td class="ps-3">
                            <a asp-controller="Task"
                               asp-action="Detail"
                               asp-route-id="@task.Id"
                               class="text-decoration-none fw-semibold text-dark">
                                @task.Title
                            </a>
                            @if (task.HasActiveTimer)
                            {
                                <span class="badge bg-danger ms-1"
                                      style="font-size:0.6rem">● LIVE</span>
                            }
                        </td>
                        <td><span class="@statusClass">@task.StatusDisplay</span></td>
                        <td><span class="@priorityClass">@task.PriorityDisplay</span></td>
                        <td class="small text-muted">
                            @(task.AssignedUserName ?? "Unassigned")
                        </td>
                        <td class="small text-muted">
                            @(task.DueDate.HasValue
                                ? task.DueDate.Value.ToString("MMM dd")
                                : "—")
                        </td>
                        <td class="small text-muted">
                            @(task.TotalHoursLogged > 0
                                ? $"{task.TotalHoursLogged:F1}h"
                                : "—")
                        </td>
                        <td class="text-end pe-3">
                            <a asp-controller="Task"
                               asp-action="Detail"
                               asp-route-id="@task.Id"
                               class="btn btn-sm btn-outline-info"
                               title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}