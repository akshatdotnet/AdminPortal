@using PMS.Domain.Enums
@using TaskStatus = PMS.Domain.Enums.TaskStatus
@using TaskPriority = PMS.Domain.Enums.TaskPriority
@{
    bool isEdit = ViewData.Model is PMS.Application.DTOs.Task.UpdateTaskDto;
    string formId = isEdit ? "editTaskForm" : "createTaskForm";
    string actionUrl = isEdit ? "/Task/Update" : "/Task/Create";

    var projects = ViewBag.Projects as IEnumerable<PMS.Application.DTOs.Project.ProjectDto>
                   ?? Enumerable.Empty<PMS.Application.DTOs.Project.ProjectDto>();
    var users = ViewBag.Users as IEnumerable<PMS.Domain.Entities.User>
                   ?? Enumerable.Empty<PMS.Domain.Entities.User>();
}

<form id="@formId" novalidate>
    @Html.AntiForgeryToken()

    @if (isEdit)
    {
        var m = (PMS.Application.DTOs.Task.UpdateTaskDto)Model;
        <input type="hidden" name="Id" value="@m.Id" />
    }

    <div class="row g-3 p-1">

        @* {{!-- Title --}} *@
        <div class="col-12">
            <label class="form-label fw-semibold">
                Task Title <span class="text-danger">*</span>
            </label>
            @if (isEdit)
            {
                var m = (PMS.Application.DTOs.Task.UpdateTaskDto)Model;
                <input type="text" name="Title" value="@m.Title"
                       class="form-control" placeholder="Enter task title"
                       maxlength="200" required />
            }
            else
            {
                <input type="text" name="Title"
                       class="form-control" placeholder="Enter task title"
                       maxlength="200" required />
            }
            <div class="invalid-feedback" data-valmsg="Title"></div>
        </div>

        @* {{!-- Description --}} *@
        <div class="col-12">
            <label class="form-label fw-semibold">Description</label>
            @if (isEdit)
            {
                var m = (PMS.Application.DTOs.Task.UpdateTaskDto)Model;
                <textarea name="Description" class="form-control"
                          rows="3" maxlength="2000"
                          placeholder="Task details...">@m.Description</textarea>
            }
            else
            {
                <textarea name="Description" class="form-control"
                          rows="3" maxlength="2000"
                          placeholder="Task details..."></textarea>
            }
            <div class="invalid-feedback" data-valmsg="Description"></div>
        </div>

        @* {{!-- Project --}} *@
        <div class="col-md-6">
            <label class="form-label fw-semibold">
                Project <span class="text-danger">*</span>
            </label>
            @{
                int selectedProjectId = isEdit
                ? ((PMS.Application.DTOs.Task.UpdateTaskDto)Model).ProjectId
                : ((PMS.Application.DTOs.Task.CreateTaskDto)Model).ProjectId;
            }
            <select name="ProjectId" class="form-select" required>
                <option value="">— Select Project —</option>
                @foreach (var p in projects)
                {
                    <option value="@p.Id"
                            selected="@(selectedProjectId == p.Id)">
                        @p.Name
                    </option>
                }
            </select>
            <div class="invalid-feedback" data-valmsg="ProjectId"></div>
        </div>

        @* {{!-- Assigned User --}} *@
        <div class="col-md-6">
            <label class="form-label fw-semibold">Assign To</label>
            @{
                int? selectedUserId = isEdit
                ? ((PMS.Application.DTOs.Task.UpdateTaskDto)Model).AssignedUserId
                : ((PMS.Application.DTOs.Task.CreateTaskDto)Model).AssignedUserId;
            }
            <select name="AssignedUserId" class="form-select">
                <option value="">— Unassigned —</option>
                @foreach (var u in users)
                {
                    <option value="@u.Id"
                            selected="@(selectedUserId == u.Id)">
                        @u.FullName
                    </option>
                }
            </select>
        </div>

        @* {{!-- Status --}} *@
        <div class="col-md-4">
            <label class="form-label fw-semibold">Status</label>
            @{
                TaskStatus selectedStatus = isEdit
                ? ((PMS.Application.DTOs.Task.UpdateTaskDto)Model).Status
                : ((PMS.Application.DTOs.Task.CreateTaskDto)Model).Status;
            }
            <select name="Status" class="form-select">
                @foreach (TaskStatus s in Enum.GetValues(typeof(TaskStatus)))
                {
                    <option value="@((int)s)" selected="@(selectedStatus == s)">
                        @s.ToString()
                    </option>
                }
            </select>
        </div>

        @* {{!-- Priority --}} *@
        <div class="col-md-4">
            <label class="form-label fw-semibold">Priority</label>
            @{
                TaskPriority selectedPriority = isEdit
                ? ((PMS.Application.DTOs.Task.UpdateTaskDto)Model).Priority
                : ((PMS.Application.DTOs.Task.CreateTaskDto)Model).Priority;
            }
            <select name="Priority" class="form-select">
                @foreach (TaskPriority p in Enum.GetValues(typeof(TaskPriority)))
                {
                    <option value="@((int)p)" selected="@(selectedPriority == p)">
                        @p.ToString()
                    </option>
                }
            </select>
        </div>

        @* {{!-- Due Date --}} *@
        <div class="col-md-4">
            <label class="form-label fw-semibold">Due Date</label>
            @if (isEdit)
            {
                var m = (PMS.Application.DTOs.Task.UpdateTaskDto)Model;
                <input type="date" name="DueDate"
                       value="@(m.DueDate.HasValue ? m.DueDate.Value.ToString("yyyy-MM-dd") : "")"
                       class="form-control" />
            }
            else
            {
                <input type="date" name="DueDate" class="form-control" />
            }
            <div class="invalid-feedback" data-valmsg="DueDate"></div>
        </div>

    </div>

    <div class="modal-footer px-0 pb-0 mt-3">
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </button>
        <button type="submit"
                class="btn btn-primary"
                id="btnSubmitTask">
            <span class="spinner-border spinner-border-sm d-none me-1"
                  id="taskSubmitSpinner"></span>
            <i class="bi bi-check-circle me-1" id="taskSubmitIcon"></i>
            @(isEdit ? "Update Task" : "Create Task")
        </button>
    </div>
</form>

<script>
    window._taskFormAction = '@actionUrl';
    window._taskFormId     = '@formId';
</script>