@{ ViewData["Title"] = "Store Settings"; ViewData["Nav"] = "Store"; }
<div class="card" style="max-width:600px;padding:28px">
  <div class="section-title">Store Settings</div>
  <p style="color:var(--c-t2);font-size:13.5px;line-height:1.8">
    <strong>Extend this view</strong> with a form bound to the <code>StoreSettings</code> entity
    via a new <code>StoreService</code>. Fields to include:<br/>
    Store name · Currency symbol · Tax rate (GST%) ·
    Free shipping threshold · Default shipping cost · Support email · Logo URL.
  </p>
  <div style="margin-top:16px;background:var(--c-hover);border-radius:8px;padding:14px;font-family:var(--fm);font-size:12.5px;color:var(--c-t2)">
    Current: StoreName = "Zovo Store" · Currency = INR · TaxRate = 18% · Free shipping ≥ ₹500
  </div>
</div>
