@model ProductDetailDto
@{ ViewData["Title"] = Model.Name; ViewData["Nav"] = "Products"; }

<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
  <a asp-action="Index" class="btn btn-secondary btn-sm">← Back</a>
  <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit Product</a>
</div>

<div style="display:grid;grid-template-columns:1fr 300px;gap:20px">
  <div class="card" style="padding:26px">
    <div class="section-title">@Model.Name</div>
    <div class="detail-row"><span class="dl">SKU</span><span class="dv" style="font-family:var(--fm)">@(Model.SKU ?? "—")</span></div>
    <div class="detail-row"><span class="dl">Category</span><span class="dv"><span class="badge bd-default">@Model.Category</span></span></div>
    @if (!string.IsNullOrEmpty(Model.SubCategory)) {
      <div class="detail-row"><span class="dl">Sub-category</span><span class="dv">@Model.SubCategory</span></div>
    }
    <div class="detail-row"><span class="dl">Price</span><span class="dv price">₹@Model.Price.ToString("N0")</span></div>
    @if (Model.CompareAtPrice.HasValue) {
      <div class="detail-row"><span class="dl">Compare-at</span><span class="dv" style="text-decoration:line-through;color:var(--c-t3)">₹@Model.CompareAtPrice.Value.ToString("N0")</span></div>
    }
    @if (Model.CostPrice.HasValue) {
      <div class="detail-row"><span class="dl">Cost Price</span><span class="dv">₹@Model.CostPrice.Value.ToString("N0")</span></div>
    }
    <div class="detail-row"><span class="dl">Stock</span><span class="dv @(Model.Stock==0?"sk-out":Model.Stock<=Model.LowStockThreshold?"sk-low":"sk-high")">@Model.Stock units</span></div>
    <div class="detail-row"><span class="dl">Low Stock At</span><span class="dv">@Model.LowStockThreshold units</span></div>
    <div class="detail-row"><span class="dl">Weight</span><span class="dv">@Model.Weight kg</span></div>
    <div class="detail-row"><span class="dl">Status</span><span class="dv"><span class="badge @(Model.IsActive?"bd-active":"bd-inactive")">@(Model.IsActive?"Active":"Inactive")</span></span></div>
    <div class="detail-row"><span class="dl">Featured</span><span class="dv">@(Model.IsFeatured ? "Yes ★" : "No")</span></div>
    <div class="detail-row"><span class="dl">Created</span><span class="dv">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</span></div>
    <div class="detail-row"><span class="dl">Updated</span><span class="dv">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</span></div>
    @if (!string.IsNullOrEmpty(Model.Tags)) {
      <div class="detail-row"><span class="dl">Tags</span><span class="dv">@Model.Tags</span></div>
    }
    @if (!string.IsNullOrEmpty(Model.Description)) {
      <div style="margin-top:16px;font-size:13.5px;color:var(--c-t2);line-height:1.7">@Model.Description</div>
    }
  </div>

  <div>
    @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
      <div class="card" style="padding:16px;margin-bottom:16px">
        <img src="@Model.ImageUrl" alt="@Model.Name" style="width:100%;border-radius:8px;object-fit:contain;max-height:240px"/>
      </div>
    }
    <div class="card" style="padding:16px">
      <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--c-t3);margin-bottom:12px">Margin</div>
      @if (Model.CostPrice.HasValue && Model.CostPrice > 0) {
        var margin = Math.Round((Model.Price - Model.CostPrice.Value) / Model.Price * 100, 1);
        <div style="font-family:var(--fd);font-size:28px;font-weight:700;color:var(--c-accent)">@margin%</div>
        <div style="font-size:12px;color:var(--c-t3)">₹@((Model.Price - Model.CostPrice.Value).ToString("N0")) per unit</div>
      } else {
        <div style="color:var(--c-t3);font-size:13px">Set cost price to see margin</div>
      }
    </div>
  </div>
</div>
