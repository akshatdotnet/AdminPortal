@model CustomerDetailDto
@* @{ ViewData["Title"] = Model.FullName; ViewData["Nav"] = "Customers"; } *@
@{
    ViewData["Title"] = Model.FirstName; ViewData["Nav"] = "Customers";
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
  <a asp-action="Index" class="btn btn-secondary btn-sm">← Customers</a>
  <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
</div>

<div style="display:grid;grid-template-columns:1fr 280px;gap:20px">
  <div class="card" style="padding:26px">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px">
      <div class="avatar av44">@Model.FirstName.Substring(0,1)</div>
      <div>
        <div style="font-family:var(--fd);font-size:18px;font-weight:700">@Model.FirstName @Model.LastName</div>
        <span class="badge bd-@Model.Status.ToLower()">@Model.Status</span>
      </div>
    </div>
    <div class="detail-row"><span class="dl">Email</span><span class="dv">@Model.Email</span></div>
    @if (!string.IsNullOrEmpty(Model.Phone)) {
      <div class="detail-row"><span class="dl">Phone</span><span class="dv">@Model.Phone</span></div>
    }
    <div class="detail-row"><span class="dl">Member Since</span><span class="dv">@Model.CreatedAt.ToString("dd MMM yyyy")</span></div>
    <div class="detail-row"><span class="dl">Total Orders</span><span class="dv" style="font-weight:700">@Model.OrderCount</span></div>
    <div class="detail-row"><span class="dl">Total Spent</span><span class="dv price">₹@Model.TotalSpent.ToString("N0")</span></div>
    @if (!string.IsNullOrEmpty(Model.Notes)) {
      <div style="margin-top:16px;background:var(--c-hover);padding:12px 14px;border-radius:8px;font-size:13.5px;color:var(--c-t2)">@Model.Notes</div>
    }
  </div>

  <div class="card" style="padding:20px">
    <div class="section-title">Saved Addresses</div>
    @if (!Model.Addresses.Any()) {
      <p style="color:var(--c-t3);font-size:13px">No addresses saved.</p>
    }
    @foreach (var a in Model.Addresses) {
      <div style="border:1px solid var(--c-border);border-radius:8px;padding:12px;margin-bottom:10px;font-size:13px">
        @if (a.IsDefault) { <span class="badge bd-active" style="margin-bottom:6px;display:inline-flex">Default</span> }
        <div style="color:var(--c-t2)">@a.Line1</div>
        @if (!string.IsNullOrEmpty(a.Line2)) { <div style="color:var(--c-t2)">@a.Line2</div> }
        <div style="color:var(--c-t3)">@a.City, @a.State @a.PostalCode</div>
        <div style="color:var(--c-t3)">@a.Country</div>
      </div>
    }
  </div>
</div>
