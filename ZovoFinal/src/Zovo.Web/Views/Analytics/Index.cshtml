@{ ViewData["Title"] = "Analytics"; ViewData["Nav"] = "Analytics"; }

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px">
  <div class="stat-card teal">
    <div class="stat-label">Total Revenue</div>
    <div class="stat-value">₹@(((decimal)ViewBag.Revenue).ToString("N0"))</div>
  </div>
  <div class="stat-card green">
    <div class="stat-label">Total Orders</div>
    <div class="stat-value">@ViewBag.Orders</div>
  </div>
  <div class="stat-card amber">
    <div class="stat-label">Avg Order Value</div>
    <div class="stat-value">₹@((ViewBag.Orders > 0 ? ((decimal)ViewBag.Revenue / (int)ViewBag.Orders) : 0m).ToString("N0"))</div>
  </div>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:20px">
  <div class="card">
    <div class="card-header"><span class="card-title">Monthly Revenue (Last 6 Months)</span></div>
    <div style="padding:20px"><canvas id="revenueChart" height="220"></canvas></div>
  </div>
  <div class="card">
    <div class="card-header"><span class="card-title">Inventory by Category</span></div>
    <div style="padding:20px"><canvas id="catChart" height="220"></canvas></div>
  </div>
</div>

<div class="card">
  <div class="card-header"><span class="card-title">Category Breakdown</span></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Category</th><th>Products</th><th>Inventory Value</th></tr></thead>
      <tbody>
      @foreach (var c in (IEnumerable<dynamic>)ViewBag.Categories) {
        <tr>
          <td><span class="badge bd-default">@c.Category</span></td>
          <td style="font-weight:600">@c.ProductCount</td>
          <td><span class="price">₹@(((decimal)c.InventoryValue).ToString("N0"))</span></td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const monthly  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((IEnumerable<dynamic>)ViewBag.Monthly).Select(m => new { label=(string)m.Label, rev=(decimal)m.Revenue })));
const cats     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((IEnumerable<dynamic>)ViewBag.Categories).Select(c => new { label=(string)c.Category, val=(decimal)c.InventoryValue })));
const palette  = ['#0ea5a0','#10b981','#f59e0b','#3b82f6','#8b5cf6','#ef4444','#06b6d4'];

new Chart(document.getElementById('revenueChart'), {
  type: 'bar',
  data: { labels: monthly.map(d=>d.label), datasets: [{ data: monthly.map(d=>d.rev), backgroundColor: '#0ea5a0', borderRadius: 6, borderSkipped: false }] },
  options: { plugins:{ legend:{ display:false } }, scales:{ y:{ grid:{ color:'#f3f4f6' }, ticks:{ color:'#9ca3af', callback: v => '₹'+v.toLocaleString() } }, x:{ grid:{ display:false }, ticks:{ color:'#9ca3af' } } } }
});

new Chart(document.getElementById('catChart'), {
  type: 'doughnut',
  data: { labels: cats.map(d=>d.label), datasets: [{ data: cats.map(d=>d.val), backgroundColor: palette, borderWidth: 2, borderColor:'#fff' }] },
  options: { plugins:{ legend:{ position:'bottom', labels:{ boxWidth:10, font:{ size:11 } } } }, cutout:'60%' }
});
</script>
}
