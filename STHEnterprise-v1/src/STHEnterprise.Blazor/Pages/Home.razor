@page "/"

<div class="setup-card">

    <h2>Complete your store setup...</h2>
    <p class="text-muted">
        Use high quality images and product descriptions to have a great looking product page.
        Let's get started.
    </p>

    <div class="setup-step done">
        <span class="icon">✔</span>
        <div>
            <strong>Your e-commerce store is ready!</strong>
            <p>Congratulations! Your e-commerce store is now live.</p>
            <a href="#">Visit store</a>
        </div>
    </div>

    <div class="setup-step done">
        <span class="icon">✔</span>
        <div>
            <strong>Add your first product</strong>
            <p>Start adding products to your online store now!</p>
            <a href="#">View product</a>
        </div>
    </div>

    <div class="setup-step">
        <span class="icon pending"></span>
        <div>
            <strong>Set up payments</strong>
            <p>Choose how you would like to receive payment for your orders.</p>
            <button class="btn btn-primary">Set up</button>
        </div>
    </div>

</div>
