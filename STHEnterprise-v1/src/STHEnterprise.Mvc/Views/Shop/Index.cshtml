@{
    Layout = "_Layout"; // or your public layout
    var categories = ViewBag.Categories as List<Category>;
    var products = ViewBag.Products as List<Product>;
    int selectedCategory = ViewBag.SelectedCategory;
}

<div class="container-fluid py-3">

    <!-- HEADER -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center gap-2">
            <img src="/images/logo.png" height="40" />
            <strong>Suraj Tea House</strong>
        </div>

        <input class="form-control w-50"
               placeholder="Search for products..." />

        <div class="d-flex gap-4">
            <span>Categories</span>
            <span>Cart <span id="cartCount" class="badge bg-danger">0</span></span>
            <span>Account</span>
        </div>
    </div>

    <div class="row">

        <!-- LEFT : CATEGORIES -->
        <div class="col-md-3 border-end">
            <ul class="list-group list-group-flush">
                @foreach (var c in categories)
                {
                    <li class="list-group-item @(c.Id == selectedCategory ? "fw-bold text-primary" : "")">
                        <a href="/Shop?categoryId=@c.Id"
                           class="text-decoration-none">
                            @c.Name (@c.ProductCount)
                        </a>
                    </li>
                }
            </ul>
        </div>

        <!-- CENTER : PRODUCTS -->
        <div class="col-md-5">
            <h5 class="mb-3">
                @categories.First(x => x.Id == selectedCategory).Name
            </h5>

            @foreach (var p in products)
            {
                <div class="card mb-3">
                    <div class="row g-0 align-items-center">
                        <div class="col-4">
                            <img src="@p.ImageUrl" class="img-fluid rounded" />
                        </div>
                        <div class="col-5">
                            <h6>@p.Name</h6>
                            <strong>₹@p.Price</strong>
                            <del class="text-muted ms-2">₹@p.MRP</del>
                            @if (p.DiscountPercent > 0)
                            {
                                <span class="badge bg-success ms-2">
                                    @p.DiscountPercent% OFF
                                </span>
                            }
                        </div>
                        <div class="col-3 text-end">
                            <button class="btn btn-outline-primary add-to-cart"
                                    data-id="@p.Id">
                                ADD +
                            </button>
                        </div>
                    </div>
                </div>
            }

            <button class="btn btn-light w-100">
                SEE ALL PRODUCTS →
            </button>
        </div>

        <!-- RIGHT : CART -->
        <div class="col-md-4 border-start">
            <h5>
                Cart <span class="badge bg-primary" id="cartBadge">0</span>
                <a href="#" class="float-end small">Clear cart</a>
            </h5>

            <div id="cartItems" class="mt-3 text-muted">
                Your cart is empty
            </div>

            <hr />

            <div class="d-flex justify-content-between">
                <strong>Sub total</strong>
                <strong id="subTotal">₹0</strong>
            </div>

            <button class="btn btn-primary w-100 mt-3">
                Go to cart
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = {};

        $(".add-to-cart").on("click", function () {
            const id = $(this).data("id");

            cart[id] = (cart[id] || 0) + 1;

            $("#cartCount, #cartBadge").text(
                Object.values(cart).reduce((a, b) => a + b, 0)
            );

            renderCart();
        });

        function renderCart() {
            let html = "";
            let total = 0;

            for (const id in cart) {
                html += `<div class="mb-2">
                            Product ${id} × ${cart[id]}
                        </div>`;
                total += 100 * cart[id]; // mock price
            }

            $("#cartItems").html(html || "Your cart is empty");
            $("#subTotal").text("₹" + total);
        }
    </script>
}
