@model CartVM
@{
    ViewData["Title"] = "Cart";
    Layout = "_ClientLayout";
}

<div class="container my-4">

    <!-- STEP 1 -->
    @* <partial name="_CheckoutStepper" /> *@


    <h4 class="mb-3">Shopping Cart (@Model.Items.Count item)</h4>

    @foreach (var item in Model.Items)
    {
        <div class="row align-items-center border-bottom py-3">
            <div class="col-3 col-md-2">
                <img src="@item.ImageUrl" class="img-fluid rounded" />
            </div>

            <div class="col-5 col-md-4">
                <strong>@item.Name</strong><br />
                ₹@item.Price
            </div>

            <div class="col-2">
                <input type="number"
                       class="form-control"
                       value="@item.Quantity"
                       min="1"
                       onchange="updateQty(@item.ProductId, this.value)" />
            </div>

            <div class="col-2 text-end fw-bold">
                ₹@item.Total
            </div>
        </div>
    }

    <div class="row mt-4">
        <div class="col-md-6 offset-md-6">
            <div class="border p-3 rounded">
                <div class="d-flex justify-content-between">
                    <span>Subtotal</span>
                    <span>₹@Model.SubTotal</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>GST (18%)</span>
                    <span>₹@Model.Tax</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between fw-bold">
                    <span>Grand Total</span>
                    <span>₹@Model.GrandTotal</span>
                </div>

                <a href="/checkout/index"
                   class="btn btn-primary w-100 mt-3">
                    Continue
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateQty(id, qty) {
            $.post('/cart/update', { productId: id, qty: qty })
             .done(() => location.reload());
        }
    </script>
}


