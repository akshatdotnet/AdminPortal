@model StoreViewModel
@{
    ViewData["Title"] = "Store";
    Layout = null;
    
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<style>
    body { background:#f8f9fa; }
    .category-list li { padding:8px 12px; cursor:pointer; }
    .category-list .active { background:#e9f2ff; border-left:4px solid #0d6efd; }
    .product-card img { width:80px; height:80px; object-fit:cover; border-radius:8px; }
    .cart-box { background:#fff; border:1px solid #ddd; padding:16px; border-radius:8px; }
    footer { background:#111; color:#fff; padding:40px 0; margin-top:60px; }
</style>

<div class="container-fluid mt-3">

    <!-- HEADER -->
    <div class="row mb-3">
        <div class="col-md-3 fw-bold fs-5">@Model.StoreInfo.StoreName</div>
        <div class="col-md-6">
            <input class="form-control" placeholder="Search for products..." />
        </div>
        <div class="col-md-3 text-end">
            <span class="me-3">Categories</span>
            <span class="me-3">Cart <span class="badge bg-danger" id="cartCount">0</span></span>
            <span>Account</span>
        </div>
    </div>

    <div class="row">

        <!-- LEFT CATEGORIES -->
        <div class="col-md-2">
            <ul class="list-unstyled category-list">
                @foreach (var c in Model.Categories)
                {
                    <li class="@(c.Active ? "active" : "")">
                        @c.Name (@c.Count)
                    </li>
                }
            </ul>
        </div>

        <!-- PRODUCTS -->
        <div class="col-md-7">
            <h5>Catering Services <span class="badge bg-primary">@Model.Products.Count</span></h5>

            @foreach (var p in Model.Products)
            {
                <div class="d-flex align-items-center justify-content-between border-bottom py-3 product-card"
                     data-id="@p.Id" data-price="@p.Price">

                    <div class="d-flex align-items-center gap-3">
                        <img src="@p.Image" />
                        <div>
                            <div class="fw-semibold">@p.Name</div>
                            <div class="text-muted">₹@p.Price</div>
                        </div>
                    </div>

                    <button class="btn btn-outline-primary add-btn">ADD +</button>
                </div>
            }

            <button class="btn btn-light mt-3">SEE ALL PRODUCTS →</button>
        </div>

        <!-- CART -->
        <div class="col-md-3">
            <div class="cart-box">
                <h6>Cart <span class="badge bg-primary" id="cartItems">0</span></h6>
                <div id="cartList"></div>

                <hr />
                <div class="d-flex justify-content-between fw-bold">
                    <span>Sub total</span>
                    <span>₹<span id="total">0</span></span>
                </div>

                <button class="btn btn-primary w-100 mt-3">Go to cart</button>
            </div>
        </div>
    </div>
</div>

<!-- FOOTER -->
<footer>
    <div class="container text-center">
        <div class="row">
            <div class="col">🚚 Free delivery<br /><small>3–5 days</small></div>
            <div class="col">💳 Payment options<br /><small>COD / Online</small></div>
            <div class="col">📞 Support<br /><small>@Model.StoreInfo.Email</small></div>
        </div>

        <hr class="my-4" />

        <strong>@Model.StoreInfo.StoreName</strong><br />
        <small>@Model.StoreInfo.Address</small>
    </div>
</footer>

<script>
    let cart = {};
    function refreshCart() {
        let total = 0, count = 0;
        $("#cartList").html("");

        $.each(cart, function (id, item) {
            total += item.qty * item.price;
            count += item.qty;

            $("#cartList").append(`
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>${item.name}</span>
                    <div>
                        <button class="btn btn-sm btn-outline-secondary minus" data-id="${id}">−</button>
                        ${item.qty}
                        <button class="btn btn-sm btn-outline-secondary plus" data-id="${id}">+</button>
                    </div>
                </div>
            `);
        });

        $("#total").text(total);
        $("#cartCount, #cartItems").text(count);
    }

    $(".add-btn").click(function () {
        let row = $(this).closest(".product-card");
        let id = row.data("id");

        if (!cart[id]) {
            cart[id] = {
                name: row.find(".fw-semibold").text(),
                price: row.data("price"),
                qty: 1
            };
        } else {
            cart[id].qty++;
        }
        refreshCart();
    });

    $(document).on("click", ".plus", function () {
        cart[$(this).data("id")].qty++;
        refreshCart();
    });

    $(document).on("click", ".minus", function () {
        let id = $(this).data("id");
        cart[id].qty--;
        if (cart[id].qty <= 0) delete cart[id];
        refreshCart();
    });
</script>
