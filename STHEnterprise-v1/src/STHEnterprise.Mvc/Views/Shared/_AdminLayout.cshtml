<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - STH Enterprise</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />

    <!-- Admin Layout CSS -->
    <link rel="stylesheet" href="~/css/admin-layout.css" />

    @RenderSection("Styles", required: false)

    <!-- Apply saved theme before paint -->
    <script>
        (function () {
            const theme = localStorage.getItem("theme") || "light";
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
</head>

<body>

    <div class="admin-layout">

        <!-- ================= SIDEBAR ================= -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <span class="logo-icon">STH</span>
                <span class="logo-text">STH Enterprise</span>                
                
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i>
                        <span class="menu-text">Dashboard</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Home" asp-action="Customers">
                        <i class="bi bi-people"></i>
                        <span class="menu-text">Customers</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Home" asp-action="Reports">
                        <i class="bi bi-bar-chart"></i>
                        <span class="menu-text">Reports</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Home" asp-action="Privacy">
                        <i class="bi bi-shield-lock"></i>
                        <span class="menu-text">Privacy</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- ================= MAIN ================= -->
        <div class="main-wrapper">

            <!-- ================= TOPBAR ================= -->
            <header class="topbar">
                <div class="d-flex align-items-center gap-2">
                    <button id="toggleSidebar"
                            class="btn btn-outline-secondary"
                            aria-label="Toggle sidebar">
                        <i class="bi bi-list"></i>
                    </button>

                    <span class="fw-bold d-none d-sm-inline">
                        STH Enterprise
                    </span>
                </div>

                <div class="d-flex align-items-center gap-3">

                    <!-- Theme Toggle -->
                    <button id="themeToggle"
                            class="btn btn-outline-secondary"
                            aria-label="Toggle theme">
                        <i class="bi bi-moon-stars"></i>
                    </button>

                    <!-- Profile Dropdown -->
                    <div class="dropdown profile-dropdown">
                        <a class="profile-trigger"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-person-circle profile-avatar"></i>
                            <i class="bi bi-chevron-down small"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end profile-menu shadow">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Home"
                                   asp-action="Profile">
                                    <i class="bi bi-person"></i>
                                    <span>Profile</span>
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Account"
                                   asp-action="Login">
                                    
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Logout</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- ================= CONTENT ================= -->
            <main class="content-area">
                @RenderBody()
            </main>

            <!-- ================= FOOTER ================= -->
            <footer class="footer text-center">
                © 2026 STH Enterprise · Powered by VSV Technologies
            </footer>
        </div>
    </div>

    <!-- ================= WHATSAPP ================= -->
    <a href="https://wa.me/919999999999"
       class="whatsapp-btn"
       target="_blank"
       aria-label="Chat on WhatsApp">
        <i class="bi bi-whatsapp"></i>
    </a>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-layout.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
