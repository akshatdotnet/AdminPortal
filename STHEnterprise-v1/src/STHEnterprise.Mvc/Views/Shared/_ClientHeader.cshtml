                <input class="form-control" placeholder="Search for products..." />
            </div>

            <!-- NAV -->
            <div class="col-md-4 text-end">
                @* <a href="/categories" class="me-3 text-dark text-decoration-none">
                    <i class="bi bi-grid"></i> Categories
                </a>

                <a href="/cart" class="me-3 text-dark text-decoration-none position-relative">
