@if (ViewBag.ShowPolicyBar == true)
{
    <div class="bg-primary text-white py-2">
        <div class="container d-flex gap-3 small">
            <a class="text-white text-decoration-none">Privacy Policy</a>
            <a class="text-white text-decoration-none">Refund policy</a>
            <a class="text-white text-decoration-none">Terms & conditions</a>
        </div>
    </div>
}


