@model int

@*
Model:
1 = Cart
2 = Address
3 = Info
4 = Payment
*@



<div class="checkout-steps mb-4">
    <div class="d-flex justify-content-between text-center">

        <div class="step @(Model >= 1 ? "active" : "")">
            <span class="circle">1</span>
            <div>Cart</div>
        </div>

        <div class="step @(Model >= 2 ? "active" : "")">
            <span class="circle">2</span>
            <div>Address</div>
        </div>

        <div class="step @(Model >= 3 ? "active" : "")">
            <span class="circle">3</span>
            <div>Info</div>
        </div>

        <div class="step @(Model >= 4 ? "active" : "")">
            <span class="circle">4</span>
            <div>Payment</div>
        </div>

    </div>
</div>

