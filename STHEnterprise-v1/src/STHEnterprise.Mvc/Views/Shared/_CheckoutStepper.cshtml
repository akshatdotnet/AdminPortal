<style>
    .stepper {
        display: flex;
        justify-content: space-between;
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .stepper li {
            text-align: center;
            flex: 1;
            position: relative;
            color: #adb5bd;
        }

            .stepper li span {
                width: 36px;
                height: 36px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                background: #dee2e6;
                margin-bottom: 6px;
                font-weight: 600;
            }

            .stepper li.active span {
                background: #0d6efd;
                color: #fff;
            }

            .stepper li.active label {
                color: #0d6efd;
                font-weight: 600;
            }

            .stepper li::after {
                content: '';
                position: absolute;
                top: 18px;
                right: -50%;
                width: 100%;
                height: 2px;
                background: #dee2e6;
                z-index: -1;
            }

            .stepper li:last-child::after {
                display: none;
            }

            .stepper li.active::after {
                background: #0d6efd;
            }

    @@media (max-width: 576px) {
        .stepper label

    {
        font-size: 12px;
    }

    }
</style>
