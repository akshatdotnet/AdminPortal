@model CreateProductCommand
@{ bool isEdit = (int)(ViewData["Id"] ?? 0) > 0;
   ViewData["Title"] = isEdit ? "Edit Product" : "Add Product";
   ViewData["Nav"] = "Products";
   var cats = ViewData["Categories"] as IEnumerable<string> ?? Enumerable.Empty<string>(); }

<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
  <a asp-action="Index" class="btn btn-secondary btn-sm">← Back</a>
  <h2 style="font-family:var(--fd);font-size:15px;font-weight:700;margin:0">
    @(isEdit ? "Edit Product" : "New Product")
  </h2>
</div>

<form asp-action="@(isEdit?"Edit":"Create")" method="post">
  @Html.AntiForgeryToken()
  @if (isEdit) { <input type="hidden" name="Id" value="@ViewData["Id"]"/> }

  <!-- Basic Info -->
  <div class="card" style="padding:26px;margin-bottom:16px">
    <div class="section-title">Basic Information</div>
    <div class="form-grid">
      <div class="fg">
        <label class="f-label">Name <span class="req">*</span></label>
        <input asp-for="Name" class="f-ctrl" placeholder="e.g. Cotton T-Shirt"/>
        <span asp-validation-for="Name" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">SKU</label>
        <input asp-for="SKU" class="f-ctrl" placeholder="e.g. CLO-001"/>
        <span class="f-hint">Auto-generated if blank</span>
      </div>
      <div class="fg">
        <label class="f-label">Category <span class="req">*</span></label>
        <select asp-for="Category" class="f-ctrl">
          <option value="">Select category…</option>
          @foreach (var c in cats) { <option value="@c">@c</option> }
          <option value="Clothing">Clothing</option>
          <option value="Electronics">Electronics</option>
          <option value="Food & Beverages">Food & Beverages</option>
          <option value="Sports">Sports</option>
          <option value="Home & Kitchen">Home & Kitchen</option>
        </select>
        <span asp-validation-for="Category" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">Sub-category</label>
        <input asp-for="SubCategory" class="f-ctrl" placeholder="Optional"/>
      </div>
      <div class="fg full">
        <label class="f-label">Description</label>
        <textarea asp-for="Description" class="f-ctrl" rows="3" placeholder="Product description…"></textarea>
      </div>
      <div class="fg full">
        <label class="f-label">Tags</label>
        <input asp-for="Tags" class="f-ctrl" placeholder="summer, sale, new (comma-separated)"/>
      </div>
    </div>
  </div>

  <!-- Pricing -->
  <div class="card" style="padding:26px;margin-bottom:16px">
    <div class="section-title">Pricing & Inventory</div>
    <div class="form-grid-3">
      <div class="fg">
        <label class="f-label">Price (₹) <span class="req">*</span></label>
        <input asp-for="Price" type="number" step="0.01" min="0" class="f-ctrl" placeholder="0.00"/>
        <span asp-validation-for="Price" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">Compare-at Price (₹)</label>
        <input asp-for="CompareAtPrice" type="number" step="0.01" min="0" class="f-ctrl" placeholder="Was price"/>
      </div>
      <div class="fg">
        <label class="f-label">Cost Price (₹)</label>
        <input asp-for="CostPrice" type="number" step="0.01" min="0" class="f-ctrl" placeholder="Your cost"/>
      </div>
      <div class="fg">
        <label class="f-label">Stock Qty <span class="req">*</span></label>
        <input asp-for="Stock" type="number" min="0" class="f-ctrl" placeholder="0"/>
        <span asp-validation-for="Stock" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">Low Stock Alert At</label>
        <input asp-for="LowStockThreshold" type="number" min="1" class="f-ctrl" placeholder="10"/>
        <span class="f-hint">Alert when stock ≤ this</span>
      </div>
      <div class="fg">
        <label class="f-label">Weight (kg)</label>
        <input asp-for="Weight" type="number" step="0.001" min="0" class="f-ctrl" placeholder="0.000"/>
      </div>
    </div>
  </div>

  <!-- Visibility -->
  <div class="card" style="padding:26px;margin-bottom:16px">
    <div class="section-title">Media & Visibility</div>
    <div class="form-grid">
      <div class="fg full">
        <label class="f-label">Image URL</label>
        <input asp-for="ImageUrl" class="f-ctrl" placeholder="https://example.com/image.jpg"/>
        <span asp-validation-for="ImageUrl" class="f-err"></span>
      </div>
      <div class="fg" style="flex-direction:row;align-items:center;gap:12px;padding-top:8px">
        <label class="toggle">
          <input asp-for="IsActive" type="checkbox"/>
          <span class="toggle-track"></span>
        </label>
        <div><div class="f-label" style="margin:0">Active</div><div class="f-hint">Visible in store</div></div>
      </div>
      <div class="fg" style="flex-direction:row;align-items:center;gap:12px;padding-top:8px">
        <label class="toggle">
          <input asp-for="IsFeatured" type="checkbox"/>
          <span class="toggle-track"></span>
        </label>
        <div><div class="f-label" style="margin:0">Featured</div><div class="f-hint">Highlight on homepage</div></div>
      </div>
    </div>
  </div>

  <div class="form-actions" style="border:none;padding-top:0">
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    <button type="submit" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      @(isEdit ? "Save Changes" : "Create Product")
    </button>
  </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScripts");} }
