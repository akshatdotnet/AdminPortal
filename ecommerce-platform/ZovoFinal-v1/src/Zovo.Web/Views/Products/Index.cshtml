@model PagedResult<ProductListItemDto>
@{ ViewData["Title"] = "Products"; ViewData["Nav"] = "Products";
   var search = ViewData["Search"] as string;
   var category = ViewData["Category"] as string;
   var status = ViewData["Status"] as string;
   var sortBy = ViewData["SortBy"] as string ?? "name_asc";
   var cats = ViewData["Categories"] as IEnumerable<string> ?? Enumerable.Empty<string>(); }

@if (TempData["Alert"] is string alert) {
  var parts = alert.Split('|', 2);
  <div class="alert alert-@parts[0]"><span>@parts[1]</span>
  <button class="alert-dismiss" onclick="this.parentElement.remove()">✕</button></div>
}

<form id="filterForm" method="get" asp-action="Index">
<div class="toolbar">
  <div class="tb-find">
    <svg class="s-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="filterSearch" name="search" value="@search" placeholder="Name, SKU…"/>
  </div>
  <select name="category" class="z-sel auto-filter">
    <option value="">All categories</option>
    @foreach (var c in cats) { <option value="@c" selected="@(category==c?"selected":null)">@c</option> }
  </select>
  <select name="status" class="z-sel auto-filter">
    <option value="">All status</option>
    <option value="active"   selected="@(status=="active"   ?"selected":null)">Active</option>
    <option value="inactive" selected="@(status=="inactive" ?"selected":null)">Inactive</option>
    <option value="low"      selected="@(status=="low"      ?"selected":null)">Low Stock</option>
    <option value="out"      selected="@(status=="out"      ?"selected":null)">Out of Stock</option>
  </select>
  <select name="sortBy" class="z-sel auto-filter">
    <option value="name_asc"  selected="@(sortBy=="name_asc" ?"selected":null)">Name A–Z</option>
    <option value="name_desc" selected="@(sortBy=="name_desc"?"selected":null)">Name Z–A</option>
    <option value="price_asc" selected="@(sortBy=="price_asc"?"selected":null)">Price ↑</option>
    <option value="price_desc"selected="@(sortBy=="price_desc"?"selected":null)">Price ↓</option>
    <option value="stock_asc" selected="@(sortBy=="stock_asc"?"selected":null)">Stock ↑</option>
    <option value="newest"    selected="@(sortBy=="newest"   ?"selected":null)">Newest</option>
  </select>
  <span class="tb-count">@Model.TotalCount product@(Model.TotalCount!=1?"s":"")</span>
  <a class="btn btn-primary" asp-action="Create">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add Product
  </a>
</div>
</form>

<div class="card">
  @if (!Model.Items.Any()) {
    <div class="empty-state">
      <div style="font-size:40px;margin-bottom:12px">📦</div>
      <h3>No products found</h3>
      <p>Adjust your filters or add your first product.</p>
    </div>
  } else {
  <div class="table-wrap">
    <table>
      <thead><tr><th>Product</th><th>SKU</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th></th></tr></thead>
      <tbody>
      @foreach (var p in Model.Items) {
        <tr data-id="@p.Id">
          <td>
            <div class="item-cell">
              <div class="thumb">
                @if (!string.IsNullOrEmpty(p.ImageUrl)) { <img src="@p.ImageUrl" alt="@p.Name"/> }
                else {
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                }
              </div>
              <div>
                <div class="item-name">@p.Name</div>
                @if (p.IsFeatured) { <div style="font-size:10px;color:var(--c-warn);font-weight:600;margin-top:2px">★ Featured</div> }
              </div>
            </div>
          </td>
          <td><span class="item-sub">@(p.SKU ?? "—")</span></td>
          <td><span class="badge bd-default">@p.Category</span></td>
          <td><span class="price">₹@p.Price.ToString("N0")</span></td>
          <td><span class="sk-@p.StockLevel">@p.StockDisplay</span></td>
          <td>
            <label class="toggle" title="@(p.IsActive?"Deactivate":"Activate")">
              <input type="checkbox" @(p.IsActive?"checked":"") onchange="toggleProduct(@p.Id,this)"/>
              <span class="toggle-track"></span>
            </label>
          </td>
          <td>
            <div class="action-wrap">
              <div class="dot-btn" data-dd>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
              </div>
              <div class="dropdown">
                <a class="dd-item" asp-action="Edit" asp-route-id="@p.Id">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Edit
                </a>
                <a class="dd-item" asp-action="Detail" asp-route-id="@p.Id">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  Details
                </a>
                <div class="dd-divider"></div>
                <button class="dd-item danger" onclick="openDeleteModal(@p.Id,'@Html.Raw(p.Name.Replace("'","\\\'"))','/Products/Delete')">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                  Delete
                </button>
              </div>
            </div>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>

  @if (Model.TotalPages > 1) {
    <div class="pager">
      <span class="pager-info">
        Showing @((Model.Page-1)*Model.PageSize+1)–@(Math.Min(Model.Page*Model.PageSize,Model.TotalCount)) of @Model.TotalCount
      </span>
      <div class="pager-btns">
        <a class="pg-btn @(!Model.HasPreviousPage?"disabled":"")"
           asp-action="Index" asp-route-page="@(Model.Page-1)"
           asp-route-search="@search" asp-route-category="@category"
           asp-route-status="@status" asp-route-sortBy="@sortBy">‹</a>
        @for (int i = Math.Max(1,Model.Page-2); i <= Math.Min(Model.TotalPages,Model.Page+2); i++) {
          <a class="pg-btn @(i==Model.Page?"active":"")"
             asp-action="Index" asp-route-page="@i"
             asp-route-search="@search" asp-route-category="@category"
             asp-route-status="@status" asp-route-sortBy="@sortBy">@i</a>
        }
        <a class="pg-btn @(!Model.HasNextPage?"disabled":"")"
           asp-action="Index" asp-route-page="@(Model.Page+1)"
           asp-route-search="@search" asp-route-category="@category"
           asp-route-status="@status" asp-route-sortBy="@sortBy">›</a>
      </div>
    </div>
  }
  }
</div>
@Html.AntiForgeryToken()
