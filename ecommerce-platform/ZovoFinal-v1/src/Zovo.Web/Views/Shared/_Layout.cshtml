<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Zovo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link rel="stylesheet" href="~/css/zovo.css" asp-append-version="true"/>
</head>
<body>
<div class="app">

  <!-- ── Sidebar ───────────────────────────────────────── -->
  <aside class="sidebar">
    <div class="sb-header">
      <div class="brand">
        <div class="brand-mark">
          <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
        </div>
        <div>
          <div class="brand-name">Zovo</div>
          <div class="brand-sub">Commerce</div>
        </div>
      </div>
    </div>

    <div class="sb-section">
      <div class="sb-label">Main</div>
      <a class="nav-link @(ViewData["Nav"]?.ToString()=="Dashboard"?"active":"")" asp-controller="Dashboard" asp-action="Index">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="8" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="15" width="7" height="6" rx="1.5"/></svg>
        Dashboard
      </a>
      <a class="nav-link @(ViewData["Nav"]?.ToString()=="Orders"?"active":"")" asp-controller="Orders" asp-action="Index">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
        Orders
        @if (ViewData["PendingOrders"] is int p && p > 0) {
          <span class="nav-badge">@p</span>
        }
      </a>
      <a class="nav-link @(ViewData["Nav"]?.ToString()=="Products"?"active":"")" asp-controller="Products" asp-action="Index">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        Products
      </a>
      <a class="nav-link @(ViewData["Nav"]?.ToString()=="Customers"?"active":"")" asp-controller="Customers" asp-action="Index">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Customers
      </a>
    </div>

    <div class="sb-section">
      <div class="sb-label">Insights</div>
      <a class="nav-link @(ViewData["Nav"]?.ToString()=="Analytics"?"active":"")" asp-controller="Analytics" asp-action="Index">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Analytics
      </a>
    </div>

    <div class="sb-section">
      <div class="sb-label">Settings</div>
      <a class="nav-link @(ViewData["Nav"]?.ToString()=="Store"?"active":"")" asp-controller="Store" asp-action="Index">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
        Store Settings
      </a>
      <a class="nav-link" asp-controller="Account" asp-action="ChangePassword">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Security
      </a>
    </div>

    <div class="sb-footer">
      <div class="avatar av34">A</div>
      <div>
        <div class="user-name">Admin</div>
        <div class="user-role">Store Owner</div>
      </div>
      <a href="#" class="logout-btn" title="Sign out">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </aside>

  <!-- ── Main ──────────────────────────────────────────── -->
  <div class="main">
    <header class="topbar">
      <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>
      <div class="tb-search">
        <svg class="s-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Quick search…"/>
      </div>
      <div class="tb-right">
        <button class="icon-btn" title="Notifications" style="position:relative">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
          <span class="notif-dot"></span>
        </button>
        <div class="avatar av34" style="cursor:pointer">A</div>
      </div>
    </header>

    <main class="page-body">@RenderBody()</main>
  </div>
</div>

<!-- ── Delete Confirm Modal ─────────────────────────────── -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">Confirm Delete</span>
      <button class="icon-btn" onclick="closeDeleteModal()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      Are you sure you want to delete <strong id="deleteTarget"></strong>?
      This action cannot be undone.
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeDeleteModal()">Cancel</button>
      <button class="btn btn-danger btn-sm" id="confirmDeleteBtn" onclick="confirmDelete()">Delete</button>
    </div>
  </div>
</div>

<script src="~/js/zovo.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
