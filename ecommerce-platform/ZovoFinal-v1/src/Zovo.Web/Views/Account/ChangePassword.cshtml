@{ ViewData["Title"] = "Security"; }
<div class="card" style="max-width:480px;padding:28px">
  <div class="section-title">Change Password</div>
  <p style="color:var(--c-t2);font-size:13.5px;line-height:1.8">
    Add <strong>ASP.NET Core Identity</strong> to enable authentication.<br/>
    Install: <code>Microsoft.AspNetCore.Identity.EntityFrameworkCore</code><br/>
    Then use <code>UserManager&lt;IdentityUser&gt;.ChangePasswordAsync()</code>
    with current + new password inputs validated here.
  </p>
</div>
