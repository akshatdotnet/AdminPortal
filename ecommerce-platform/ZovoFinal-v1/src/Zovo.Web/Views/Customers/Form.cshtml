@model CreateCustomerCommand
@{ bool isEdit = (Model is UpdateCustomerCommand);
   ViewData["Title"] = isEdit ? "Edit Customer" : "Add Customer";
   ViewData["Nav"] = "Customers"; }

<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
  <a asp-action="Index" class="btn btn-secondary btn-sm">← Back</a>
  <h2 style="font-family:var(--fd);font-size:15px;font-weight:700;margin:0">@(isEdit?"Edit Customer":"New Customer")</h2>
</div>

<form asp-action="@(isEdit?"Edit":"Create")" method="post" style="max-width:680px">
  @Html.AntiForgeryToken()
  @if (Model is UpdateCustomerCommand upd) { <input type="hidden" name="Id" value="@upd.Id"/> }

  <div class="card" style="padding:26px">
    <div class="section-title">Customer Information</div>
    <div class="form-grid">
      <div class="fg">
        <label class="f-label">First Name <span class="req">*</span></label>
        <input asp-for="FirstName" class="f-ctrl" placeholder="Priya"/>
        <span asp-validation-for="FirstName" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">Last Name <span class="req">*</span></label>
        <input asp-for="LastName" class="f-ctrl" placeholder="Sharma"/>
        <span asp-validation-for="LastName" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">Email <span class="req">*</span></label>
        <input asp-for="Email" type="email" class="f-ctrl" placeholder="email@example.com"/>
        <span asp-validation-for="Email" class="f-err"></span>
      </div>
      <div class="fg">
        <label class="f-label">Phone</label>
        <input asp-for="Phone" class="f-ctrl" placeholder="+91 98765 43210"/>
      </div>
      <div class="fg full">
        <label class="f-label">Notes</label>
        <textarea asp-for="Notes" class="f-ctrl" rows="3" placeholder="Internal notes about this customer…"></textarea>
      </div>
    </div>
    <div class="form-actions">
      <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        @(isEdit ? "Save Changes" : "Create Customer")
      </button>
    </div>
  </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScripts");} }
