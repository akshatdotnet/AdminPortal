@model PagedResult<CustomerListItemDto>
@{ ViewData["Title"] = "Customers"; ViewData["Nav"] = "Customers";
   var search = ViewData["Search"] as string;
   var status = ViewData["Status"] as string; }

@if (TempData["Alert"] is string alert) {
  var parts = alert.Split('|', 2);
  <div class="alert alert-@parts[0]"><span>@parts[1]</span>
  <button class="alert-dismiss" onclick="this.parentElement.remove()">✕</button></div>
}

<form id="filterForm" method="get" asp-action="Index">
<div class="toolbar">
  <div class="tb-find">
    <svg class="s-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="filterSearch" name="search" value="@search" placeholder="Name, email…"/>
  </div>
  <select name="status" class="z-sel auto-filter">
    <option value="">All status</option>
    @foreach (var s in Enum.GetNames<CustomerStatus>()) {
      <option value="@s" selected="@(status==s?"selected":null)">@s</option>
    }
  </select>
  <span class="tb-count">@Model.TotalCount customer@(Model.TotalCount!=1?"s":"")</span>
  <a class="btn btn-primary" asp-action="Create">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add Customer
  </a>
</div>
</form>

<div class="card">
  @if (!Model.Items.Any()) {
    <div class="empty-state"><div style="font-size:40px;margin-bottom:12px">👥</div><h3>No customers found</h3></div>
  } else {
  <div class="table-wrap">
    <table>
      <thead><tr><th>Customer</th><th>Email</th><th>Orders</th><th>Total Spent</th><th>Status</th><th>Joined</th><th></th></tr></thead>
      <tbody>
      @foreach (var c in Model.Items) {
        <tr data-id="@c.Id">
          <td>
            <div class="item-cell">
              <div class="avatar av34" style="flex-shrink:0">@c.FullName.Substring(0,1)</div>
              <div class="item-name">@c.FullName</div>
            </div>
          </td>
          <td style="font-size:13px;color:var(--c-t2)">@c.Email</td>
          <td style="font-weight:600;text-align:center">@c.OrderCount</td>
          <td><span class="price">₹@c.TotalSpent.ToString("N0")</span></td>
          <td><span class="badge bd-@c.Status.ToLower()">@c.Status</span></td>
          <td style="color:var(--c-t3);font-size:12px">@c.CreatedAt.ToString("dd MMM yyyy")</td>
          <td>
            <div class="action-wrap">
              <div class="dot-btn" data-dd>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
              </div>
              <div class="dropdown">
                <a class="dd-item" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                <a class="dd-item" asp-action="Detail" asp-route-id="@c.Id">View Details</a>
                <button class="dd-item" onclick="toggleCustomer(@c.Id)">Toggle Status</button>
                <div class="dd-divider"></div>
                <button class="dd-item danger" onclick="openDeleteModal(@c.Id,'@Html.Raw(c.FullName.Replace("'","\\\'"))','/Customers/Delete')">Delete</button>
              </div>
            </div>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
  @if (Model.TotalPages > 1) {
    <div class="pager">
      <span class="pager-info">@Model.TotalCount customers</span>
      <div class="pager-btns">
        <a class="pg-btn @(!Model.HasPreviousPage?"disabled":"")" asp-action="Index" asp-route-page="@(Model.Page-1)" asp-route-search="@search">‹</a>
        @for (int i=1;i<=Model.TotalPages;i++) {
          <a class="pg-btn @(i==Model.Page?"active":"")" asp-action="Index" asp-route-page="@i" asp-route-search="@search">@i</a>
        }
        <a class="pg-btn @(!Model.HasNextPage?"disabled":"")" asp-action="Index" asp-route-page="@(Model.Page+1)" asp-route-search="@search">›</a>
      </div>
    </div>
  }
  }
</div>
@Html.AntiForgeryToken()
