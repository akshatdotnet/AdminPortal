@model WalletSystem.ViewModels.ForgotPasswordVM
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="auth-form-wrap">
    <div class="auth-form-header">
        <div class="auth-back-link"><a href="/Auth/Login">← Back to sign in</a></div>
        <div class="auth-icon-circle gold-circle">🔑</div>
        <h2>Reset your password</h2>
        <p class="text-muted">Enter your email and we'll send you a reset link.</p>
    </div>

    <form asp-action="ForgotPassword" method="post" class="auth-form">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="Email">Email Address</label>
            <div class="input-icon-wrap">
                <span class="input-icon">✉</span>
                <input asp-for="Email" class="form-input with-icon" type="email"
                       placeholder="alice@example.com" autofocus autocomplete="email" />
            </div>
            <span asp-validation-for="Email" class="field-error"></span>
        </div>

        <button type="submit" class="btn-auth">
            <span>Send Reset Link</span>
            <span class="btn-arrow">→</span>
        </button>
    </form>
</div>
