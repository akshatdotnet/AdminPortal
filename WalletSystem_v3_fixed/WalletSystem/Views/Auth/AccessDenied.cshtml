@{
    ViewData["Title"] = "Access Denied";
    Layout = "_AuthLayout";
}

<div class="auth-form-wrap" style="text-align:center">
    <div class="auth-error-big">403</div>
    <h2>Access Denied</h2>
    <p class="text-muted">You don't have permission to view this page.</p>
    <div style="margin-top:28px; display:flex; gap:12px; justify-content:center">
        <a href="/" class="btn-auth" style="max-width:180px">Go to Dashboard</a>
        <a href="/Auth/Login" class="btn-ghost">Sign In Again</a>
    </div>
</div>
