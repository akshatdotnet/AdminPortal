@{
    ViewData["Title"] = "Users";
    var filter = ViewBag.Filter as UserFilterVM ?? new UserFilterVM();
    var paged  = ViewBag.Paged  as PagedResult<UserListVM> ?? new PagedResult<UserListVM>();
}

<div class="toolbar">
    <form method="get" class="filter-form">
        <div class="filter-row">
            <input name="Search" value="@filter.Search" placeholder="Search name, email, username…" class="input-search" />
            <select name="Status" class="input-select">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<UserStatus>())
                {
                    <option value="@s" @@(filter.Status= =s ? "selected" : "" )>@s</option>
                }
            </select>
            <select name="PageSize" class="input-select input-sm">
                @foreach (var n in new[]{5,10,25,50})
                {
                    <option value="@n" @@(filter.PageSize= =n ? "selected" : "" )>@n / page</option>
                }
            </select>
            <input type="hidden" name="SortBy"  value="@filter.SortBy" />
            <input type="hidden" name="SortDir" value="@filter.SortDir" />
            <button type="submit" class="btn-primary">Filter</button>
            <a href="/Users" class="btn-ghost">Reset</a>
        </div>
    </form>
    <a href="/Users/Create" class="btn-primary">+ New User</a>
</div>

<div class="card">
    <div class="table-meta">
        Showing @((paged.Page-1)*paged.PageSize+1)–@Math.Min(paged.Page*paged.PageSize,paged.TotalCount)
        of <strong>@paged.TotalCount</strong> users
    </div>

    <table class="data-table">
        <thead>
            <tr>
                @{
                    string SortLink(string col) {
                        var dir = filter.SortBy == col && filter.SortDir == "asc" ? "desc" : "asc";
                        return $"/Users?Search={filter.Search}&Status={filter.Status}&PageSize={filter.PageSize}&SortBy={col}&SortDir={dir}";
                    }
                    string SortIcon(string col) => filter.SortBy == col ? (filter.SortDir == "asc" ? " ↑" : " ↓") : "";
                }
                <th><a href="@SortLink("FullName")">Name @SortIcon("FullName")</a></th>
                <th><a href="@SortLink("Email")">Email @SortIcon("Email")</a></th>
                <th>Phone</th>
                <th>Username</th>
                <th>Status</th>
                <th><a href="@SortLink("Balance")">Balance @SortIcon("Balance")</a></th>
                <th>Wallet</th>
                <th><a href="@SortLink("CreatedAt")">Created @SortIcon("CreatedAt")</a></th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in paged.Items)
        {
            <tr>
                <td><strong>@u.FullName</strong></td>
                <td class="text-muted">@u.Email</td>
                <td class="mono text-muted">@u.PhoneNumber</td>
                <td class="mono">@@u.Username</td>
                <td><span class="status-pill status-@u.Status.ToString().ToLower()">@u.Status</span></td>
                <td class="amount">@(u.WalletBalance.HasValue ? u.WalletBalance.Value.ToString("C") : "–")</td>
                <td>
                    @if (u.WalletStatus.HasValue)
                    {
                        <span class="status-pill status-@u.WalletStatus.Value.ToString().ToLower()">@u.WalletStatus</span>
                    }
                    else { <span class="text-muted">None</span> }
                </td>
                <td class="text-muted">@u.CreatedAt.ToString("MMM d, yyyy")</td>
                <td>
                    <div class="action-btns">
                        <a href="/Users/Details/@u.Id" class="btn-xs">View</a>
                        <a href="/Users/Edit/@u.Id" class="btn-xs btn-ghost">Edit</a>
                        <form method="post" action="/Users/Delete/@u.Id" style="display:inline"
                              onsubmit="return confirm('Delete @u.FullName?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-xs btn-danger">Del</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        @if (!paged.Items.Any())
        {
            <tr><td colspan="9" class="empty-row">No users found.</td></tr>
        }
        </tbody>
    </table>

    @await Html.PartialAsync("_Pager", new PagerVM { Page = paged.Page, TotalPages = paged.TotalPages, BaseUrl = $"/Users?Search={filter.Search}&Status={filter.Status}&PageSize={filter.PageSize}&SortBy={filter.SortBy}&SortDir={filter.SortDir}" })
</div>
