@{
    ViewData["Title"] = "Transactions";
    var filter = ViewBag.Filter as TransactionFilterVM ?? new TransactionFilterVM();
    var paged  = ViewBag.Paged  as PagedResult<TransactionListVM> ?? new PagedResult<TransactionListVM>();
}

<div class="card filter-card">
    <form method="get">
        <div class="filter-row flex-wrap">
            <input name="Search" value="@filter.Search" placeholder="Search ref, description, user…" class="input-search" />
            <select name="Type" class="input-select">
                <option value="">All Types</option>
                @foreach (var t in Enum.GetValues<TransactionType>())
                {
                    <option value="@t" @@(filter.Type == t ? "selected" : "")>@t</option>
                }
            </select>
            <select name="Status" class="input-select">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<TransactionStatus>())
                {
                    <option value="@s" @@(filter.Status= =s ? "selected" : "" )>@s</option>
                }
            </select>
            <input name="DateFrom" value="@filter.DateFrom?.ToString("yyyy-MM-dd")" type="date" class="input-date" />
            <input name="DateTo"   value="@filter.DateTo?.ToString("yyyy-MM-dd")"   type="date" class="input-date" />
            <input name="MinAmount" value="@filter.MinAmount" type="number" step="0.01" placeholder="Min $" class="input-number" />
            <input name="MaxAmount" value="@filter.MaxAmount" type="number" step="0.01" placeholder="Max $" class="input-number" />
            <select name="SortDir" class="input-select input-sm">
                <option value="desc" @@(filter.SortDir= ="desc" ?"selected":"")>Newest</option>
                <option value="asc" @@(filter.SortDir= ="asc" ?"selected":"")>Oldest</option>
            </select>
            <select name="PageSize" class="input-select input-sm">
                @foreach (var n in new[]{10,25,50,100})
                {
                    <option value="@n" @@(filter.PageSize= =n?"selected":"")>@n / page</option>
                }
            </select>
            <button type="submit" class="btn-primary">Filter</button>
            <a href="/Transactions" class="btn-ghost">Reset</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="table-meta">
        Showing @((paged.Page-1)*paged.PageSize+1)–@Math.Min(paged.Page*paged.PageSize,paged.TotalCount)
        of <strong>@paged.TotalCount</strong> transactions
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Ref #</th>
                <th>User</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Before</th>
                <th>After</th>
                <th>Related</th>
                <th>Description</th>
                <th>Status</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var t in paged.Items)
        {
            var isCredit = t.Type is TransactionType.Deposit or TransactionType.Bonus or TransactionType.Refund
                        || (t.Type == TransactionType.Transfer && t.BalanceAfter > t.BalanceBefore);
            <tr>
                <td><span class="mono text-muted small">@t.ReferenceNumber</span></td>
                <td><strong>@t.OwnerName</strong></td>
                <td><span class="badge badge-@t.Type.ToString().ToLower()">@t.Type</span></td>
                <td class="amount @(isCredit ? "positive" : "negative")">
                    @(isCredit ? "+" : "−")@t.Amount.ToString("C")
                </td>
                <td class="mono text-muted small">@t.BalanceBefore.ToString("C")</td>
                <td class="mono small"><strong>@t.BalanceAfter.ToString("C")</strong></td>
                <td class="text-muted small">@(t.RelatedOwnerName ?? "–")</td>
                <td class="text-muted small">@t.Description</td>
                <td><span class="status-pill status-@t.Status.ToString().ToLower()">@t.Status</span></td>
                <td class="text-muted small">@t.CreatedAt.ToString("MMM d, HH:mm")</td>
                <td><a href="/Transactions/Details/@t.Id" class="btn-xs">View</a></td>
            </tr>
        }
        @if (!paged.Items.Any())
        {
            <tr><td colspan="11" class="empty-row">No transactions match your filters.</td></tr>
        }
        </tbody>
    </table>

    @{
        var baseUrl = $"/Transactions?Search={filter.Search}&Type={filter.Type}&Status={filter.Status}&DateFrom={filter.DateFrom:yyyy-MM-dd}&DateTo={filter.DateTo:yyyy-MM-dd}&MinAmount={filter.MinAmount}&MaxAmount={filter.MaxAmount}&SortDir={filter.SortDir}&PageSize={filter.PageSize}";
    }
    @await Html.PartialAsync("_Pager", new PagerVM { Page = paged.Page, TotalPages = paged.TotalPages, BaseUrl = baseUrl })
</div>
