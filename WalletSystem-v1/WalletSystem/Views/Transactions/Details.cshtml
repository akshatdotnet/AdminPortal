@model WalletSystem.Models.Transaction
@{ ViewData["Title"] = "Transaction Details"; }

<div class="detail-header">
    <div class="detail-avatar txn-avatar badge-@Model.Type.ToString().ToLower()">
        @(Model.Type == TransactionType.Deposit ? "↓" :
          Model.Type == TransactionType.Withdrawal ? "↑" :
          Model.Type == TransactionType.Transfer ? "⇄" :
          Model.Type == TransactionType.Refund ? "↺" :
          Model.Type == TransactionType.Bonus ? "★" : "✦")
    </div>
    <div class="detail-info">
        <h2>@Model.Type Transaction</h2>
        <p class="mono text-muted">@Model.ReferenceNumber</p>
        <span class="status-pill status-@Model.Status.ToString().ToLower()">@Model.Status</span>
    </div>
    <div class="txn-amount-hero @(Model.BalanceAfter >= Model.BalanceBefore ? "positive" : "negative")">
        @(Model.BalanceAfter >= Model.BalanceBefore ? "+" : "−")@Model.Amount.ToString("C")
    </div>
</div>

<div class="detail-grid">
    <div class="card">
        <div class="card-title">Transaction Info</div>
        <div class="info-list">
            <div class="info-row"><span>Reference</span><strong class="mono">@Model.ReferenceNumber</strong></div>
            <div class="info-row"><span>Type</span><span class="badge badge-@Model.Type.ToString().ToLower()">@Model.Type</span></div>
            <div class="info-row"><span>Amount</span><strong>@Model.Amount.ToString("C")</strong></div>
            <div class="info-row"><span>Balance Before</span><strong class="mono">@Model.BalanceBefore.ToString("C")</strong></div>
            <div class="info-row"><span>Balance After</span><strong class="mono">@Model.BalanceAfter.ToString("C")</strong></div>
            <div class="info-row"><span>Change</span>
                <strong class="@(Model.BalanceAfter >= Model.BalanceBefore ? "positive" : "negative")">
                    @(Model.BalanceAfter >= Model.BalanceBefore ? "+" : "")@((Model.BalanceAfter - Model.BalanceBefore).ToString("C"))
                </strong>
            </div>
            <div class="info-row"><span>Status</span><span class="status-pill status-@Model.Status.ToString().ToLower()">@Model.Status</span></div>
            <div class="info-row"><span>Description</span><strong>@(Model.Description ?? "–")</strong></div>
            <div class="info-row"><span>Timestamp</span><strong>@Model.CreatedAt.ToString("MMMM d, yyyy HH:mm:ss") UTC</strong></div>
        </div>
    </div>

    <div class="card">
        <div class="card-title">Parties</div>
        <div class="info-list">
            <div class="info-row"><span>Wallet Owner</span><strong>@Model.Wallet.User.FullName</strong></div>
            <div class="info-row"><span>Username</span><strong class="mono">@@@Model.Wallet.User.Username</strong></div>
            <div class="info-row"><span>Wallet #</span><strong class="mono">#@Model.WalletId</strong></div>
            @if (Model.RelatedWallet != null)
            {
                <div class="info-row"><span>Related Party</span><strong>@Model.RelatedWallet.User.FullName</strong></div>
                <div class="info-row"><span>Related Wallet</span><strong class="mono">#@Model.RelatedWalletId</strong></div>
            }
        </div>

        <div class="mt-xl">
            <a href="/Wallets/Details/@Model.WalletId" class="btn-ghost btn-sm">View Wallet</a>
            <a href="/Users/Details/@Model.Wallet.UserId" class="btn-ghost btn-sm">View User</a>
        </div>
    </div>
</div>

<!-- Balance Flow Diagram -->
<div class="card mt-xl">
    <div class="card-title">Balance Flow</div>
    <div class="balance-flow">
        <div class="flow-item">
            <div class="flow-label">Before</div>
            <div class="flow-value mono">@Model.BalanceBefore.ToString("C")</div>
        </div>
        <div class="flow-arrow @(Model.BalanceAfter >= Model.BalanceBefore ? "arrow-green" : "arrow-red")">
            @(Model.BalanceAfter >= Model.BalanceBefore ? "+" : "−")@Model.Amount.ToString("C")
        </div>
        <div class="flow-item">
            <div class="flow-label">After</div>
            <div class="flow-value mono @(Model.BalanceAfter >= Model.BalanceBefore ? "positive" : "negative")">@Model.BalanceAfter.ToString("C")</div>
        </div>
    </div>
</div>

<div class="mt-xl">
    <a href="/Transactions" class="btn-ghost">← Back to Transactions</a>
</div>
