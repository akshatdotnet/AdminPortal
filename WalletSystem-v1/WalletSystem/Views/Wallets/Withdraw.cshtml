@model WalletSystem.ViewModels.WithdrawVM
@{ ViewData["Title"] = "Withdraw Funds"; }

<div class="form-page">
    <div class="form-card operation-card withdraw-card">
        <div class="op-icon op-red">↑</div>
        <h2 class="form-heading">Withdraw Funds</h2>
        <div class="op-wallet-info">
            <span>@Model.OwnerName</span>
            <span class="op-balance">Available: <strong>@Model.CurrentBalance.ToString("C")</strong></span>
        </div>

        <form asp-action="Withdraw" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="WalletId" type="hidden" />
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Amount">Amount (@Model.Currency)</label>
                <div class="amount-input-wrap">
                    <span class="currency-prefix">$</span>
                    <input asp-for="Amount" class="form-input amount-input" type="number" step="0.01" min="0.01"
                           max="@Model.CurrentBalance" placeholder="0.00" autofocus />
                </div>
                <span asp-validation-for="Amount" class="field-error"></span>
                <div class="quick-amounts">
                    @foreach (var pct in new[] { 25, 50, 75, 100 })
                    {
                        <button type="button" class="quick-amount-btn" data-pct="@pct" data-max="@Model.CurrentBalance">@pct%</button>
                    }
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Description">Description (optional)</label>
                <input asp-for="Description" class="form-input" placeholder="e.g. ATM withdrawal, Bill payment…" />
            </div>
            <div class="amount-preview" id="preview">
                Remaining balance: <strong id="newBalance">@Model.CurrentBalance.ToString("C")</strong>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-danger btn-lg">Confirm Withdrawal</button>
                <a href="/Wallets/Details/@Model.WalletId" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
const current = @Model.CurrentBalance;
const amtInput = document.querySelector('[name="Amount"]');
amtInput.addEventListener('input', function() {
    const v = parseFloat(this.value) || 0;
    const remaining = current - v;
    const el = document.getElementById('newBalance');
    el.textContent = '$' + remaining.toFixed(2);
    el.style.color = remaining < 0 ? 'var(--danger)' : 'var(--text)';
});
document.querySelectorAll('.quick-amount-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const pct = parseInt(this.dataset.pct);
        const max = parseFloat(this.dataset.max);
        amtInput.value = (max * pct / 100).toFixed(2);
        amtInput.dispatchEvent(new Event('input'));
    });
});
</script>
