@model WalletSystem.ViewModels.TransferVM
@{ ViewData["Title"] = "Transfer Funds"; }

<div class="form-page">
    <div class="form-card operation-card transfer-card">
        <div class="op-icon op-blue">⇄</div>
        <h2 class="form-heading">Transfer Funds</h2>
        <div class="op-wallet-info">
            <span>From: <strong>@Model.FromOwnerName</strong></span>
            <span class="op-balance">Available: <strong>@Model.FromBalance.ToString("C")</strong></span>
        </div>

        <form asp-action="Transfer" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="FromWalletId" type="hidden" />
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="RecipientIdentifier">Recipient (username or email)</label>
                <input asp-for="RecipientIdentifier" class="form-input" placeholder="e.g. bob or bob@example.com" autofocus />
                <span asp-validation-for="RecipientIdentifier" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Amount">Amount (@Model.Currency)</label>
                <div class="amount-input-wrap">
                    <span class="currency-prefix">$</span>
                    <input asp-for="Amount" class="form-input amount-input" type="number" step="0.01" min="0.01"
                           max="@Model.FromBalance" placeholder="0.00" />
                </div>
                <span asp-validation-for="Amount" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description">Note (optional)</label>
                <input asp-for="Description" class="form-input" placeholder="e.g. Dinner split, Rent…" />
            </div>
            <div class="amount-preview">
                Your balance after: <strong id="newBalance">@Model.FromBalance.ToString("C")</strong>
            </div>
            <div class="transfer-notice">
                ⚠ Transfers are instant and cannot be reversed. Double-check the recipient.
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-primary btn-lg">Send Money</button>
                <a href="/Wallets/Details/@Model.FromWalletId" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
const current = @Model.FromBalance;
document.querySelector('[name="Amount"]').addEventListener('input', function() {
    const v = parseFloat(this.value) || 0;
    const el = document.getElementById('newBalance');
    el.textContent = '$' + (current - v).toFixed(2);
    el.style.color = (current - v) < 0 ? 'var(--danger)' : 'var(--text)';
});
</script>
