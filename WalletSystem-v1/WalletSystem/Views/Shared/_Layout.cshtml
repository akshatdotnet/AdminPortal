<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – WalletOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="app-shell">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">◈</div>
            <span class="brand-name">WalletOS</span>
        </div>

        <nav class="sidebar-nav">
            <a href="/" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <span class="nav-icon">⬡</span> Dashboard
            </a>
            <a href="/Users" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                <span class="nav-icon">⬡</span> Users
            </a>
            <a href="/Wallets" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Wallets" ? "active" : "")">
                <span class="nav-icon">⬡</span> Wallets
            </a>
            <a href="/Transactions" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transactions" ? "active" : "")">
                <span class="nav-icon">⬡</span> Transactions
            </a>

            <div class="nav-divider"></div>

            <a href="/Profile" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")">
                <span class="nav-icon">⬡</span> My Profile
            </a>
        </nav>

        <!-- Sidebar user card -->
        <div class="sidebar-user-card">
            <div class="suc-avatar">@(User.FindFirst("Initials")?.Value ?? "?")</div>
            <div class="suc-info">
                <div class="suc-name">@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name)</div>
                <div class="suc-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</div>
            </div>
        </div>

        <div class="sidebar-footer">
            <form method="post" asp-controller="Auth" asp-action="Logout" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar-logout-btn">↩ Sign Out</button>
            </form>
            <div class="sys-badge">v1.0 · Live</div>
        </div>
    </aside>

    <!-- Main -->
    <main class="main-content">
        <div class="topbar">
            <h1 class="page-title">@(ViewData["Title"] ?? "Dashboard")</h1>
            <div class="topbar-right">
                <span class="env-pill">SQLite · EF Core 8</span>
                <a href="/Profile" class="topbar-avatar" title="My Profile">
                    @(User.FindFirst("Initials")?.Value ?? "?")
                </a>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✓ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">✗ @TempData["Error"]</div>
        }

        <div class="content-body">
            @RenderBody()
        </div>
    </main>
</div>

<script src="~/js/site.js"></script>
</body>
</html>
