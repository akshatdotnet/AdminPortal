@model WalletSystem.ViewModels.UserDetailVM
@{ ViewData["Title"] = "User Details"; }

<div class="detail-header">
    <div class="detail-avatar">@Model.User.FullName[0]</div>
    <div class="detail-info">
        <h2>@Model.User.FullName</h2>
        <p class="text-muted mono">@@@Model.User.Username · @Model.User.Email</p>
        <span class="status-pill status-@Model.User.Status.ToString().ToLower()">@Model.User.Status</span>
    </div>
    <div class="detail-actions">
        <a href="/Users/Edit/@Model.User.Id" class="btn-primary">Edit</a>
        <form method="post" action="/Users/ChangeStatus/@Model.User.Id" style="display:inline">
            @Html.AntiForgeryToken()
            @if (Model.User.Status == UserStatus.Active)
            {
                <input type="hidden" name="status" value="Suspended" />
                <button type="submit" class="btn-ghost">Suspend</button>
            }
            else
            {
                <input type="hidden" name="status" value="Active" />
                <button type="submit" class="btn-ghost">Activate</button>
            }
        </form>
    </div>
</div>

<div class="detail-grid">
    <!-- User Info Card -->
    <div class="card">
        <div class="card-title">Account Info</div>
        <div class="info-list">
            <div class="info-row"><span>Full Name</span><strong>@Model.User.FullName</strong></div>
            <div class="info-row"><span>Email</span><strong>@Model.User.Email</strong></div>
            <div class="info-row"><span>Phone</span><strong class="mono">@Model.User.PhoneNumber</strong></div>
            <div class="info-row"><span>Username</span><strong class="mono">@@@Model.User.Username</strong></div>
            <div class="info-row"><span>Status</span><span class="status-pill status-@Model.User.Status.ToString().ToLower()">@Model.User.Status</span></div>
            <div class="info-row"><span>Member Since</span><strong>@Model.User.CreatedAt.ToString("MMMM d, yyyy")</strong></div>
            @if (Model.User.UpdatedAt.HasValue)
            {
                <div class="info-row"><span>Last Updated</span><strong>@Model.User.UpdatedAt.Value.ToString("MMM d, yyyy HH:mm")</strong></div>
            }
        </div>
    </div>

    <!-- Wallet Card -->
    <div class="card">
        <div class="card-title">Wallet</div>
        @if (Model.Wallet != null)
        {
            <div class="wallet-balance-display">
                <div class="balance-amount">@Model.Wallet.Balance.ToString("C")</div>
                <div class="balance-label">@Model.Wallet.Currency · @Model.Wallet.Status</div>
            </div>
            <div class="info-list">
                <div class="info-row"><span>Wallet ID</span><strong class="mono">#@Model.Wallet.Id</strong></div>
                <div class="info-row"><span>Status</span><span class="status-pill status-@Model.Wallet.Status.ToString().ToLower()">@Model.Wallet.Status</span></div>
                <div class="info-row"><span>Created</span><strong>@Model.Wallet.CreatedAt.ToString("MMM d, yyyy")</strong></div>
            </div>
            <div class="wallet-quick-actions">
                <a href="/Wallets/Deposit/@Model.Wallet.Id" class="btn-primary btn-sm">Deposit</a>
                <a href="/Wallets/Withdraw/@Model.Wallet.Id" class="btn-ghost btn-sm">Withdraw</a>
                <a href="/Wallets/Transfer/@Model.Wallet.Id" class="btn-ghost btn-sm">Transfer</a>
                <a href="/Wallets/Details/@Model.Wallet.Id" class="btn-ghost btn-sm">Full View</a>
            </div>
        }
        else
        {
            <div class="empty-state-sm">No wallet assigned.</div>
        }
    </div>
</div>

<!-- Recent Transactions -->
<div class="section-header mt-xl">
    <h2>Recent Transactions</h2>
    @if (Model.Wallet != null)
    {
        <a href="/Wallets/Details/@Model.Wallet.Id" class="btn-link">View all →</a>
    }
</div>

<div class="card">
    @if (Model.RecentTransactions.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ref #</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Balance After</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var t in Model.RecentTransactions)
            {
                <tr>
                    <td><span class="mono text-muted">@t.ReferenceNumber</span></td>
                    <td><span class="badge badge-@t.Type.ToString().ToLower()">@t.Type</span></td>
                    <td class="amount @(t.Type == TransactionType.Deposit || t.Type == TransactionType.Bonus || t.Type == TransactionType.Refund ? "positive" : "negative")">
                        @(t.Type == TransactionType.Deposit || t.Type == TransactionType.Bonus || t.Type == TransactionType.Refund ? "+" : "-")@t.Amount.ToString("C")
                    </td>
                    <td class="mono">@t.BalanceAfter.ToString("C")</td>
                    <td class="text-muted">@t.Description</td>
                    <td><span class="status-pill status-@t.Status.ToString().ToLower()">@t.Status</span></td>
                    <td class="text-muted">@t.CreatedAt.ToString("MMM d, HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-row">No transactions yet.</div>
    }
</div>

<div class="mt-xl">
    <a href="/Users" class="btn-ghost">← Back to Users</a>
</div>
