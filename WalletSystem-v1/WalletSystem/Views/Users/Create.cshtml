@* Create.cshtml *@
@model WalletSystem.ViewModels.UserCreateVM
@{ ViewData["Title"] = "New User"; }

<div class="form-page">
    <div class="form-card">
        <h2 class="form-heading">Create User Account</h2>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-section-title">Personal Info</div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" class="form-input" placeholder="Alice Johnson" />
                    <span asp-validation-for="FullName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Username"></label>
                    <input asp-for="Username" class="form-input" placeholder="alice" />
                    <span asp-validation-for="Username" class="field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-input" type="email" placeholder="alice@example.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" class="form-input" placeholder="555-0101" />
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Status"></label>
                <select asp-for="Status" class="form-input" asp-items="Html.GetEnumSelectList<UserStatus>()"></select>
            </div>

            <div class="form-section-title">Wallet Setup</div>
            <div class="form-group checkbox-group">
                <input asp-for="CreateWallet" type="checkbox" class="form-checkbox" id="createWallet" />
                <label for="createWallet">Create wallet for this user</label>
            </div>
            <div id="walletFields" class="form-row">
                <div class="form-group">
                    <label asp-for="InitialBalance"></label>
                    <input asp-for="InitialBalance" class="form-input" type="number" step="0.01" min="0" />
                    <span asp-validation-for="InitialBalance" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Currency"></label>
                    <select asp-for="Currency" class="form-input">
                        <option value="USD">USD – US Dollar</option>
                        <option value="EUR">EUR – Euro</option>
                        <option value="GBP">GBP – British Pound</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Create User</button>
                <a href="/Users" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
document.getElementById('createWallet').addEventListener('change', function() {
    document.getElementById('walletFields').style.display = this.checked ? 'flex' : 'none';
});
if (!document.getElementById('createWallet').checked)
    document.getElementById('walletFields').style.display = 'none';
</script>
