@model WalletSystem.ViewModels.UserEditVM
@{ ViewData["Title"] = "Edit User"; }

<div class="form-page">
    <div class="form-card">
        <h2 class="form-heading">Edit User #@Model.Id</h2>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" class="form-input" />
                    <span asp-validation-for="FullName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Username"></label>
                    <input asp-for="Username" class="form-input" />
                    <span asp-validation-for="Username" class="field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-input" type="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" class="form-input" />
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Status"></label>
                <select asp-for="Status" class="form-input" asp-items="Html.GetEnumSelectList<UserStatus>()"></select>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-primary">Save Changes</button>
                <a href="/Users" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>
