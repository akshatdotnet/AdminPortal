@{
    ViewData["Title"] = "Check Your Email";
    Layout = "_AuthLayout";
    var email     = TempData["ResetEmail"]?.ToString();
    var resetLink = TempData["ResetLink"]?.ToString();
}

<div class="auth-form-wrap">
    <div class="auth-form-header" style="text-align:center">
        <div class="auth-success-icon">✓</div>
        <h2>Check your email</h2>
        <p class="text-muted">
            If an account exists for <strong>@(email ?? "that address")</strong>,
            you'll receive a password reset link shortly.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(resetLink))
    {
        <div class="demo-reset-box">
            <div class="demo-title">⚡ Development Mode — Direct Reset Link</div>
            <p class="text-muted" style="font-size:12px;margin-bottom:10px">
                In production, this link is sent by email. For demo purposes, click below:
            </p>
            <a href="@resetLink" class="btn-auth btn-auth-outline">Open Reset Link →</a>
        </div>
    }

    <div class="auth-info-box">
        <div class="info-point">✓ Reset links expire after <strong>2 hours</strong></div>
        <div class="info-point">✓ Only the most recent link is valid</div>
        <div class="info-point">✓ Your account stays secure</div>
    </div>

    <div style="text-align:center; margin-top:24px">
        <a href="/Auth/ForgotPassword" class="btn-ghost">Resend Email</a>
        &nbsp;
        <a href="/Auth/Login" class="btn-ghost">Back to Login</a>
    </div>
</div>
