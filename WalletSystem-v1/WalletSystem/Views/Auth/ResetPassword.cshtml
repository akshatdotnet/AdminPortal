@model WalletSystem.ViewModels.ResetPasswordVM
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_AuthLayout";
}

<div class="auth-form-wrap">
    <div class="auth-form-header">
        <div class="auth-icon-circle blue-circle">🔒</div>
        <h2>Create new password</h2>
        <p class="text-muted">Choose a strong password for <strong>@Model.Email</strong></p>
    </div>

    <form asp-action="ResetPassword" method="post" class="auth-form">
        @Html.AntiForgeryToken()
        <input asp-for="Token" type="hidden" />
        <input asp-for="Email" type="hidden" />

        <div asp-validation-summary="All" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="NewPassword">New Password</label>
            <div class="input-icon-wrap">
                <span class="input-icon">◉</span>
                <input asp-for="NewPassword" class="form-input with-icon" type="password"
                       id="newPwd" placeholder="Minimum 8 characters" autocomplete="new-password" />
                <button type="button" class="toggle-password" onclick="toggle('newPwd')" title="Show">👁</button>
            </div>
            <span asp-validation-for="NewPassword" class="field-error"></span>
            <div class="password-strength" id="strengthBar">
                <div class="strength-track"><div class="strength-fill" id="strengthFill"></div></div>
                <span class="strength-label" id="strengthLabel"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword">Confirm New Password</label>
            <div class="input-icon-wrap">
                <span class="input-icon">◉</span>
                <input asp-for="ConfirmPassword" class="form-input with-icon" type="password"
                       id="confirmPwd" placeholder="Repeat password" autocomplete="new-password" />
                <button type="button" class="toggle-password" onclick="toggle('confirmPwd')" title="Show">👁</button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>

        <div class="password-rules">
            <div class="rule" id="ruleLen">✗ At least 8 characters</div>
            <div class="rule" id="ruleUpper">✗ One uppercase letter</div>
            <div class="rule" id="ruleNum">✗ One number</div>
        </div>

        <button type="submit" class="btn-auth" id="submitBtn">
            <span>Reset Password</span>
            <span class="btn-arrow">→</span>
        </button>
    </form>
</div>

<script>
function toggle(id) {
    const el = document.getElementById(id);
    el.type = el.type === 'password' ? 'text' : 'password';
}

document.getElementById('newPwd').addEventListener('input', function() {
    const v = this.value;
    const ruleLen   = document.getElementById('ruleLen');
    const ruleUpper = document.getElementById('ruleUpper');
    const ruleNum   = document.getElementById('ruleNum');
    const fill      = document.getElementById('strengthFill');
    const label     = document.getElementById('strengthLabel');

    const hasLen   = v.length >= 8;
    const hasUpper = /[A-Z]/.test(v);
    const hasNum   = /[0-9]/.test(v);
    const hasSpec  = /[^A-Za-z0-9]/.test(v);

    ruleLen.className   = 'rule ' + (hasLen   ? 'rule-ok' : '');
    ruleUpper.className = 'rule ' + (hasUpper ? 'rule-ok' : '');
    ruleNum.className   = 'rule ' + (hasNum   ? 'rule-ok' : '');
    ruleLen.textContent   = (hasLen   ? '✓' : '✗') + ' At least 8 characters';
    ruleUpper.textContent = (hasUpper ? '✓' : '✗') + ' One uppercase letter';
    ruleNum.textContent   = (hasNum   ? '✓' : '✗') + ' One number';

    const score = [hasLen, hasUpper, hasNum, hasSpec].filter(Boolean).length;
    const pct   = score * 25;
    const colors = ['', '#ef4444', '#f59e0b', '#3b82f6', '#10b981'];
    const labels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
    fill.style.width      = pct + '%';
    fill.style.background = colors[score] || 'transparent';
    label.textContent     = labels[score] || '';
    label.style.color     = colors[score] || 'transparent';
});
</script>
