@model UserManagement.ViewModels.UserDetailViewModel
@{ ViewData["Title"] = "User Detail"; }

<div class="page-header">
    <div>
        <h1><i class="bi bi-person-badge me-2 text-accent"></i>User Detail</h1>
        <div class="sub">Full profile and module permissions</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Profile Card -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><i class="bi bi-person me-2"></i>Profile</div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="avatar-lg mx-auto mb-3">@Model.FullName[0]</div>
                    <div style="font-size:18px;font-weight:700">@Model.FullName</div>
                    <div style="font-size:13px;color:var(--text-muted)">@@Model.Username</div>
                    <div class="mt-2">
                        <span class="@(Model.IsActive ? "badge-active" : "badge-inactive")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                </div>
                <div class="divider"></div>
                <div class="info-row">
                    <span class="info-label"><i class="bi bi-envelope me-1"></i>Email</span>
                    <span>@Model.Email</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="bi bi-calendar me-1"></i>Joined</span>
                    <span>@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="bi bi-clock me-1"></i>Last Login</span>
                    <span>
                        @(Model.LastLoginAt.HasValue
                            ? Model.LastLoginAt.Value.ToString("MMM dd, yyyy HH:mm")
                            : "Never")
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="bi bi-shield me-1"></i>Roles</span>
                    <div>
                        @foreach (var r in Model.Roles)
                        {
                            <span class="badge-role-tag">@r</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Permissions -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-key me-2"></i>Module Permissions</div>
            <div class="card-body p-0">
                @if (!Model.Permissions.Any())
                {
                    <div class="p-4 text-center text-muted">No permissions assigned yet.</div>
                }
                else
                {
                    <table class="table table-hover perm-table mb-0">
                        <thead>
                            <tr>
                                <th style="text-align:left">Role</th>
                                <th style="text-align:left">Module</th>
                                <th>View</th>
                                <th>Create</th>
                                <th>Edit</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Permissions)
                            {
                                <tr>
                                    <td><span class="badge-role-tag">@p.RoleName</span></td>
                                    <td style="font-weight:500">@p.ModuleName</td>
                                    <td class="text-center">
                                        @if (p.CanView)   { <i class="bi bi-check-circle-fill" style="color:var(--green)"></i> }
                                        else              { <span style="color:var(--text-muted)">—</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (p.CanCreate) { <i class="bi bi-check-circle-fill" style="color:var(--green)"></i> }
                                        else              { <span style="color:var(--text-muted)">—</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (p.CanEdit)   { <i class="bi bi-check-circle-fill" style="color:var(--green)"></i> }
                                        else              { <span style="color:var(--text-muted)">—</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (p.CanDelete) { <i class="bi bi-check-circle-fill" style="color:var(--green)"></i> }
                                        else              { <span style="color:var(--text-muted)">—</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
