@* _Pager.cshtml *@
@model WalletSystem.ViewModels.PagerVM

@if (Model.TotalPages > 1)
{
    <div class="pager">
        @if (Model.HasPrevious)
        {
            <a href="@Model.BaseUrl&Page=@(Model.Page-1)" class="pager-btn">← Prev</a>
        }
        else
        {
            <span class="pager-btn disabled">← Prev</span>
        }

        @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
        {
            if (i == Model.Page)
            {
                <span class="pager-btn active">@i</span>
            }
            else
            {
                <a href="@Model.BaseUrl&Page=@i" class="pager-btn">@i</a>
            }
        }

        @if (Model.HasNext)
        {
            <a href="@Model.BaseUrl&Page=@(Model.Page+1)" class="pager-btn">Next →</a>
        }
        else
        {
            <span class="pager-btn disabled">Next →</span>
        }

        <span class="pager-info">Page @Model.Page of @Model.TotalPages</span>
    </div>
}
