<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(ViewBag.StoreName ?? "Shopzo")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
<div class="admin-wrapper">

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo"><i class="bi bi-bag-check-fill"></i></div>
            <span class="brand-name">@(ViewBag.StoreName ?? "Shopzo")</span>
            <a href="#" class="brand-ext ms-auto"><i class="bi bi-box-arrow-up-right"></i></a>
        </div>

        <ul class="sidebar-nav">
            <li>
                <a asp-controller="Dashboard" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                </a>
            </li>
            <li>
                <a asp-controller="Orders" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="bi bi-bag"></i><span>Orders</span>
                </a>
            </li>
            <li>
                <a href="#"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Delivery" ? "active" : "")">
                    <i class="bi bi-truck"></i><span>Delivery</span>
                </a>
            </li>
            <li>
                <a asp-controller="Products" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                    <i class="bi bi-grid-1x2"></i><span>Products</span>
                </a>
            </li>
            <li>
                <a asp-controller="Dashboard" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i><span>Analytics</span>
                </a>
            </li>
            <li>
                <a asp-controller="Payouts" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payouts" ? "active" : "")">
                    <i class="bi bi-wallet2"></i><span>Payouts</span>
                </a>
            </li>
            <li>
                <a asp-controller="Discounts" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Discounts" ? "active" : "")">
                    <i class="bi bi-tag"></i><span>Discounts</span>
                </a>
            </li>
            <li>
                <a asp-controller="Audience" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audience" ? "active" : "")">
                    <i class="bi bi-people"></i><span>Audience</span>
                </a>
            </li>
            <li>
                <a href="#"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appearance" ? "active" : "")">
                    <i class="bi bi-palette"></i><span>Appearance</span>
                </a>
            </li>
            <li>
                <a href="#"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Plugins" ? "active" : "")">
                    <i class="bi bi-puzzle"></i><span>Plugins</span>
                </a>
            </li>
            <li>
                <a asp-controller="Settings" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
                    <i class="bi bi-gear"></i><span>Settings</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <a href="#" class="upgrade-link">
                <i class="bi bi-gem upgrade-icon"></i>
                <div>
                    <div class="fw-600 text-white" style="font-size:13px">Upgrade plan</div>
                    <div style="font-size:11px;color:#94a3b8">Get extra benefits</div>
                </div>
            </a>
            <a asp-controller="Credits" asp-action="Index" class="credits-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Credits" ? "credits-link-active" : "")">
                <i class="bi bi-square-fill credits-icon"></i>
                <div>
                    <div style="font-size:11px;color:#94a3b8">Dukaan Credits</div>
                    <div class="fw-700 text-white" style="font-size:14px">@(ViewBag.DukaanCredits ?? "88.87")</div>
                </div>
            </a>
        </div>
    </nav>

    <!-- Main -->
    <main class="main-content">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="sidebar-toggle d-md-none" id="sidebarToggle"><i class="bi bi-list"></i></button>
                <h1 class="page-title">
                    @ViewData["Title"]
                    @if (ViewData["TitleSub"] != null)
                    {
                        <a href="#" class="how-it-works-link ms-2"><i class="bi bi-question-circle"></i> @ViewData["TitleSub"]</a>
                    }
                </h1>
            </div>
            <div class="topbar-right">
                <a href="#" class="topbar-help"><i class="bi bi-question-circle me-1"></i>Help</a>
                <div class="topbar-user d-none d-md-flex">
                    <div class="user-avatar">@User.Identity?.Name?.FirstOrDefault()</div>
                    <span class="user-name d-none d-lg-block">@User.Identity?.Name</span>
                </div>
                <button class="topbar-icon-btn"><i class="bi bi-bell"></i></button>
                <button class="topbar-icon-btn"><i class="bi bi-receipt"></i></button>
                <div class="dropdown">
                    <button class="topbar-icon-btn" data-bs-toggle="dropdown"><i class="bi bi-list"></i></button>
                    <ul class="dropdown-menu dropdown-menu-end" style="min-width:200px">
                        <li class="dropdown-item-text py-2 px-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="store-dot @(ViewBag.StoreIsOpen == true ? "dot-green" : "dot-gray")"></span>
                                <span class="fw-500 text-sm">Store status: @(ViewBag.StoreIsOpen == true ? "Open" : "Closed")</span>
                                @if (ViewBag.StoreIsOpen == true)
                                {
                                    <span class="badge-green ms-auto">Open</span>
                                }
                            </div>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-receipt me-2"></i>Billing &amp; Invoices</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-gem me-2"></i>Subscription</a></li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="flash-banner flash-success">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button class="flash-close"><i class="bi bi-x"></i></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="flash-banner flash-error">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button class="flash-close"><i class="bi bi-x"></i></button>
            </div>
        }

        <div class="page-body">
            @RenderBody()
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/admin.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
