@model AdminPortal.Application.DTOs.ForgotPasswordDto
@{
    Layout = null;
    ViewData["Title"] = "Forgot password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Forgot password — Shopzo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>
</head>
<body>
<div class="auth-bg">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-logo"><i class="bi bi-bag-check-fill"></i></div>
            <span class="auth-brand-name">shopzo</span>
        </div>

        <a asp-action="Login" asp-controller="Account" class="auth-back">
            <i class="bi bi-arrow-left me-1"></i> Back to login
        </a>

        <div class="auth-icon-circle mb-3">
            <i class="bi bi-envelope-at" style="font-size:26px;color:#1a6ef5"></i>
        </div>

        <h1 class="auth-title">Forgot your password?</h1>
        <p class="auth-subtitle">Enter your email address and we'll send you a link to reset your password.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert auth-alert-error">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @Html.ValidationSummary(excludePropertyErrors: true, message: "", htmlAttributes: new { @class = "mb-0" })
            </div>
        }

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-field">
                <label asp-for="Email" class="auth-label">Email address</label>
                <input asp-for="Email" class="auth-input"
                       type="email" placeholder="Enter your email address"
                       autocomplete="email" autofocus />
                <span asp-validation-for="Email" class="auth-validation"></span>
            </div>

            <button type="submit" class="auth-btn">Send reset link</button>
        </form>

        <p class="auth-footer-text mt-3">
            Remember your password? <a asp-action="Login" asp-controller="Account" class="auth-link">Log in</a>
        </p>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
