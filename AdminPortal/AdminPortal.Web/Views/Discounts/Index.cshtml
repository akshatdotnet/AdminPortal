@model DiscountsViewModel
@{
    ViewData["Title"] = "Discounts";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex gap-3">
        <div class="kpi-mini">
            <span class="text-muted">Active</span>
            <span class="fw-700 text-success">@Model.TotalActive</span>
        </div>
        <div class="kpi-mini">
            <span class="text-muted">Expired</span>
            <span class="fw-700 text-muted">@Model.TotalExpired</span>
        </div>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createDiscountModal">
        <i class="bi bi-plus-lg me-1"></i> Create Discount
    </button>
</div>

<div class="card-panel">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Description</th>
                    <th>Value</th>
                    <th>Usage</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Discounts)
                {
                    <tr class="@(d.IsExpired ? "row-muted" : "")">
                        <td>
                            <span class="discount-code">@d.Code</span>
                        </td>
                        <td class="text-muted">@d.Description</td>
                        <td>
                            <span class="fw-600 @(d.Type == "Percentage" ? "text-primary" : "text-success")">
                                @d.DisplayValue
                            </span>
                        </td>
                        <td>
                            @d.UsedCount @(d.UsageLimit.HasValue ? $"/ {d.UsageLimit}" : "/ ∞")
                            @if (d.UsageLimit.HasValue)
                            {
                                var pct = (int)((double)d.UsedCount / d.UsageLimit.Value * 100);
                                <div class="usage-bar">
                                    <div class="usage-fill" style="width: @pct%"></div>
                                </div>
                            }
                        </td>
                        <td class="text-muted">@(d.ExpiresAt?.ToString("dd MMM yyyy") ?? "No expiry")</td>
                        <td>
                            @if (d.IsExpired)
                            {
                                <span class="status-badge status-danger">Expired</span>
                            }
                            else
                            {
                                <span class="status-badge @(d.IsActive ? "status-delivered" : "status-cancelled")">
                                    @(d.IsActive ? "Active" : "Inactive")
                                </span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (!d.IsExpired)
                                {
                                    <form asp-action="Toggle" method="post">
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button type="submit" class="btn-icon" title="@(d.IsActive ? "Deactivate" : "Activate")">
                                            <i class="bi bi-@(d.IsActive ? "toggle-on text-success" : "toggle-off text-muted")"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="Delete" method="post"
                                      onsubmit="return confirm('Delete this discount?')">
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <button type="submit" class="btn-icon text-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Discount Modal -->
<div class="modal fade" id="createDiscountModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Discount Code</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Discount Code</label>
                            <input type="text" name="Code" class="form-control font-mono text-uppercase" placeholder="SAVE20" required style="text-transform:uppercase" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Type</label>
                            <select name="Type" class="form-select">
                                <option value="0">Percentage (%)</option>
                                <option value="1">Fixed Amount (&#8377;)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Value</label>
                            <input type="number" name="Value" class="form-control" min="1" step="1" required placeholder="20" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Usage Limit</label>
                            <input type="number" name="UsageLimit" class="form-control" min="1" placeholder="Unlimited" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <input type="text" name="Description" class="form-control" placeholder="e.g. Summer sale discount" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Expiry Date</label>
                            <input type="date" name="ExpiresAt" class="form-control" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Discount</button>
                </div>
            </form>
        </div>
    </div>
</div>
