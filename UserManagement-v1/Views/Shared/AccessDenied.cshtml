@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex flex-column align-items-center justify-content-center"
     style="min-height:60vh;text-align:center">
    <div style="font-size:72px;color:var(--red);margin-bottom:16px">
        <i class="bi bi-shield-exclamation"></i>
    </div>
    <h2 style="font-size:28px;font-weight:700;margin-bottom:8px">Access Denied</h2>
    <p style="color:var(--text-muted);max-width:400px;margin-bottom:24px">
        You don't have permission to access this resource.
        Contact your administrator if you believe this is an error.
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
        <i class="bi bi-house me-2"></i>Back to Dashboard
    </a>
</div>
