@model UserManagement.ViewModels.ModuleCreateEditViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Module" : "Add Module";
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-grid-3x3-gap me-2 text-accent"></i>@ViewData["Title"]
        </h1>
        <div class="sub">
            @(isEdit ? $"Editing: {Model.Name}" : "Register a new application module")
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-grid me-2"></i>Module Details</div>
            <div class="card-body">
                <form asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="e.g. User Management" />
                            <span asp-validation-for="Name" class="field-validation-error"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="ControllerName" class="form-label"></label>
                            <input asp-for="ControllerName" class="form-control"
                                   placeholder="e.g. Users" />
                            <span asp-validation-for="ControllerName"
                                  class="field-validation-error"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"
                                      placeholder="Brief description of this module…"></textarea>
                        </div>
                        <div class="col-sm-8">
                            <label asp-for="Icon" class="form-label">
                                Bootstrap Icon Class
                                <a href="https://icons.getbootstrap.com/" target="_blank"
                                   style="font-size:11px;color:var(--accent);margin-left:6px">
                                    Browse <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text" id="iconPreview"
                                      style="background:var(--bg-surface);border-color:var(--border);
                                             color:var(--accent);min-width:42px;justify-content:center">
                                    <i class="bi @Model.Icon" id="iconEl"></i>
                                </span>
                                <input asp-for="Icon" class="form-control"
                                       placeholder="bi-grid"
                                       id="iconInput"
                                       oninput="previewIcon(this.value)" />
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="SortOrder" class="form-label"></label>
                            <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input"
                                       type="checkbox" role="switch" />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 me-1"></i>
                            @(isEdit ? "Update Module" : "Create Module")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>Tips</div>
            <div class="card-body" style="font-size:13px;color:var(--text-secondary)">
                <p>
                    <strong style="color:var(--text-primary)">Controller Name</strong> must
                    exactly match the MVC controller class name without the
                    <code style="color:var(--cyan)">"Controller"</code> suffix.
                </p>
                <p>Example: <code style="color:var(--cyan)">Users</code> for
                    <code style="color:var(--cyan)">UsersController.cs</code></p>
                <p class="mb-0">
                    <strong style="color:var(--text-primary)">Icon</strong> uses Bootstrap Icons.
                    Enter the full class like
                    <code style="color:var(--cyan)">bi-people-fill</code>.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewIcon(val) {
            const el = document.getElementById('iconEl');
            if (el) el.className = 'bi ' + val.trim();
        }
    </script>
}
