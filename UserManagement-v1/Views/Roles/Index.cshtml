@using X.PagedList
@using UserManagement.ViewModels
@model IPagedList<RoleListViewModel>
@{
    ViewData["Title"] = "Roles";
    var filter = (ViewBag.Filter as SearchFilterViewModel) ?? new SearchFilterViewModel();
    string s  = filter.SearchTerm  ?? "";
    string st = filter.StatusFilter ?? "";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-shield-check me-2 text-accent"></i>Roles</h1>
        <div class="sub">Manage roles and their module permissions</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-shield-plus me-1"></i>Add Role
    </a>
</div>

<form method="get" asp-action="Index" class="search-bar">
    <input type="text" name="searchTerm" class="form-control" style="max-width:280px"
           placeholder="Search role name…" value="@s" />
    <select name="statusFilter" class="form-select" style="max-width:140px">
        <option value=""         selected="@(st == ""         ? "selected" : null)">All Status</option>
        <option value="active"   selected="@(st == "active"   ? "selected" : null)">Active</option>
        <option value="inactive" selected="@(st == "inactive" ? "selected" : null)">Inactive</option>
    </select>
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-search me-1"></i>Search
    </button>
    @if (!string.IsNullOrEmpty(s) || !string.IsNullOrEmpty(st))
    {
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-x me-1"></i>Clear
        </a>
    }
</form>

<div class="table-wrapper">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Role Name</th>
                <th>Description</th>
                <th>Users</th>
                <th>Status</th>
                <th>Created</th>
                <th style="width:100px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-shield d-block mb-2" style="font-size:32px"></i>
                        No roles found.
                    </td>
                </tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div style="width:32px;height:32px;border-radius:8px;
                                        background:var(--amber-soft);color:var(--amber);
                                        display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <span style="font-weight:600">@r.Name</span>
                        </div>
                    </td>
                    <td style="color:var(--text-secondary)">@r.Description</td>
                    <td>
                        <span class="badge-role-tag"
                              style="background:var(--cyan-soft);color:var(--cyan)">
                            @r.UserCount user@(r.UserCount != 1 ? "s" : "")
                        </span>
                    </td>
                    <td>
                        <span class="@(r.IsActive ? "badge-active" : "badge-inactive")">
                            @(r.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td style="font-size:12px;color:var(--text-muted)">
                        @r.CreatedAt.ToString("MMM dd, yyyy")
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@r.Id"
                               class="btn-icon edit" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" method="post"
                                  class="confirm-delete d-inline"
                                  data-name="@r.Name">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn-icon delete" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
    <div style="font-size:12px;color:var(--text-muted)">
        Showing @Model.FirstItemOnPage–@Model.LastItemOnPage of @Model.TotalItemCount roles
    </div>
    @{
        string PagerUrl(int p) => $"?page={p}&pageSize={filter.PageSize}&searchTerm={s}&statusFilter={st}";
        int totalPages = Model.PageCount;
        int curPage   = Model.PageNumber;
        int startPage = Math.Max(1, curPage - 2);
        int endPage   = Math.Min(totalPages, startPage + 4);
        if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
    }
    <ul class="pagination pagination-sm mb-0">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="@(Model.HasPreviousPage ? PagerUrl(curPage - 1) : "#")">‹</a>
        </li>
        @for (int p = startPage; p <= endPage; p++)
        {
            <li class="page-item @(p == curPage ? "active" : "")">
                <a class="page-link" href="@PagerUrl(p)">@p</a>
            </li>
        }
        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="@(Model.HasNextPage ? PagerUrl(curPage + 1) : "#")">›</a>
        </li>
    </ul>
</div>
