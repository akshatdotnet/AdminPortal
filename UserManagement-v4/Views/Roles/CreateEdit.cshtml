@model UserManagement.ViewModels.RoleCreateEditViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Role" : "Add Role";
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-@(isEdit ? "pencil-square" : "shield-plus") me-2 text-accent"></i>
            @ViewData["Title"]
        </h1>
        <div class="sub">
            @(isEdit ? $"Editing: {Model.Name}" : "Create a new role with module permissions")
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row g-3">
        <!-- Role Details -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-shield me-2"></i>Role Details</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Manager" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Describe what this role can do…"></textarea>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input"
                               type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Permission Matrix -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-key me-2"></i>Module Permissions</span>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                id="btnSelectAll">
                            <i class="bi bi-check-all me-1"></i>All
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                id="btnClearAll">
                            <i class="bi bi-x me-1"></i>None
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover perm-table mb-0">
                        <thead>
                            <tr>
                                <th style="text-align:left;padding-left:20px !important">Module</th>
                                <th>View</th>
                                <th>Create</th>
                                <th>Edit</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.ModulePermissions.Count; i++)
                            {
                                var perm = Model.ModulePermissions[i];
                                <tr>
                                    <td style="padding-left:20px !important">
                                        <input type="hidden"
                                               name="ModulePermissions[@i].ModuleId"
                                               value="@perm.ModuleId" />
                                        <input type="hidden"
                                               name="ModulePermissions[@i].ModuleName"
                                               value="@perm.ModuleName" />
                                        <input type="hidden"
                                               name="ModulePermissions[@i].ModuleIcon"
                                               value="@perm.ModuleIcon" />
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi @perm.ModuleIcon"
                                               style="color:var(--accent);font-size:15px"></i>
                                            <span style="font-weight:500">@perm.ModuleName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="form-check" style="justify-content:center">
                                            <input type="checkbox"
                                                   class="form-check-input perm-cb"
                                                   name="ModulePermissions[@i].CanView"
                                                   value="true"
                                                   @(perm.CanView ? "checked" : "") />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="form-check" style="justify-content:center">
                                            <input type="checkbox"
                                                   class="form-check-input perm-cb"
                                                   name="ModulePermissions[@i].CanCreate"
                                                   value="true"
                                                   @(perm.CanCreate ? "checked" : "") />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="form-check" style="justify-content:center">
                                            <input type="checkbox"
                                                   class="form-check-input perm-cb"
                                                   name="ModulePermissions[@i].CanEdit"
                                                   value="true"
                                                   @(perm.CanEdit ? "checked" : "") />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="form-check" style="justify-content:center">
                                            <input type="checkbox"
                                                   class="form-check-input perm-cb"
                                                   name="ModulePermissions[@i].CanDelete"
                                                   value="true"
                                                   @(perm.CanDelete ? "checked" : "") />
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2 me-1"></i>@(isEdit ? "Update Role" : "Create Role")
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.getElementById('btnSelectAll')
            ?.addEventListener('click', () =>
                document.querySelectorAll('.perm-cb')
                    .forEach(cb => cb.checked = true));
        document.getElementById('btnClearAll')
            ?.addEventListener('click', () =>
                document.querySelectorAll('.perm-cb')
                    .forEach(cb => cb.checked = false));
    </script>
}
