<!DOCTYPE html>
<html lang="en" data-theme="dark">

<!--
╔══════════════════════════════════════════════════════════════════════════════╗
║  _Layout.cshtml  –  UserHub Master Layout                                  ║
║  Structure:                                                                 ║
║    <html>                                                                   ║
║      <head>   Meta / CSS / theme-flash-prevention script                   ║
║      <body>                                                                 ║
║        [Authenticated]                                                      ║
║          .layout-shell                                                      ║
║            .l-sidebar   ← Fixed left side-navigation                       ║
║              .sidebar-header   (brand logo + mobile close)                 ║
║              .sidebar-user     (avatar + name + role)                      ║
║              .sidebar-nav      (nav items + sections)                      ║
║              .sidebar-footer   (theme switcher + logout)                   ║
║            .l-body             ← Everything right of sidebar               ║
║              .l-topbar         ← Sticky top header                         ║
║              .l-content        ← Scrollable page area                      ║
║              .l-footer         ← Bottom footer bar                         ║
║        [Unauthenticated] → RenderBody() only (login page)                  ║
╚══════════════════════════════════════════════════════════════════════════════╝
-->

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – UserHub</title>

    <!-- Vendor CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Application CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!--
        Theme flash-prevention:
        Reads the saved theme from localStorage and stamps [data-theme] on <html>
        BEFORE the first CSS paint so there is no visible colour flash on page load.
    -->
    <script>
        (function () {
            var saved = localStorage.getItem('uh-theme');
            if (saved) document.documentElement.setAttribute('data-theme', saved);
        }());
    </script>
</head>

<body>

@{
    /* ── Page-level helpers ────────────────────────────────────────────────── */
    var currentUser   = Context.Session.GetObjectFromJson<SessionUserViewModel>("CurrentUser");
    var activeCtrl    = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool isSuperAdmin = currentUser?.Roles?.Contains("SuperAdmin") ?? false;

    /* Permission helpers – used to decide which nav items to render */
    bool CanView(string moduleName) =>
        isSuperAdmin ||
        (currentUser?.Permissions?.Any(p => p.ModuleName == moduleName && p.CanView) ?? false);
}

@* ════════════════════════════════════════════════════════════════════════════
   AUTHENTICATED SHELL
   Rendered only when a valid session exists.
   ════════════════════════════════════════════════════════════════════════════ *@
@if (currentUser != null)
{
    <div class="layout-shell">

        @* ════════════════════════════════════════════════════════════════════
           LEFT SIDEBAR  –  fixed, full-height side-navigation
           ════════════════════════════════════════════════════════════════════ *@
        <aside class="l-sidebar" id="sidebar" role="navigation" aria-label="Main navigation">

            @* ── Sidebar Header: brand logo ───────────────────────────────── *@
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="brand" aria-label="UserHub home">
                    <i class="bi bi-hexagon-fill brand-icon" aria-hidden="true"></i>
                    <span class="brand-name">UserHub</span>
                </a>
                @* Mobile-only close button *@
                <button class="l-sidebar-toggle d-lg-none"
                        id="sidebarClose"
                        aria-label="Close navigation">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
            </div>

            @* ── Sidebar User: avatar + name + assigned roles ─────────────── *@
            <div class="sidebar-user" aria-label="Current user">
                <div class="user-avatar" aria-hidden="true">@currentUser.FullName[0]</div>
                <div class="user-info">
                    <div class="user-name">@currentUser.FullName</div>
                    <div class="user-roles">@string.Join(", ", currentUser.Roles)</div>
                </div>
            </div>

            @* ── Sidebar Navigation: primary nav links ────────────────────── *@
            <nav class="sidebar-nav" aria-label="Site sections">
                <ul class="nav-menu" role="list">

                    @* Dashboard – always visible *@
                    <li class="nav-item @(activeCtrl == "Home" ? "active" : "")" role="listitem">
                        <a asp-controller="Home" asp-action="Index" class="nav-link">
                            <i class="bi bi-speedometer2" aria-hidden="true"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    @* Administration section – rendered only when at least one item is accessible *@
                    @if (CanView("User Management") || CanView("Role Management") || CanView("Module Management"))
                    {
                        <li class="nav-section" role="separator" aria-label="Administration">
                            ADMINISTRATION
                        </li>
                    }

                    @if (CanView("User Management"))
                    {
                        <li class="nav-item @(activeCtrl == "Users" ? "active" : "")" role="listitem">
                            <a asp-controller="Users" asp-action="Index" class="nav-link">
                                <i class="bi bi-people-fill" aria-hidden="true"></i>
                                <span>Users</span>
                            </a>
                        </li>
                    }

                    @if (CanView("Role Management"))
                    {
                        <li class="nav-item @(activeCtrl == "Roles" ? "active" : "")" role="listitem">
                            <a asp-controller="Roles" asp-action="Index" class="nav-link">
                                <i class="bi bi-shield-check" aria-hidden="true"></i>
                                <span>Roles</span>
                            </a>
                        </li>
                    }

                    @if (CanView("Module Management"))
                    {
                        <li class="nav-item @(activeCtrl == "Modules" ? "active" : "")" role="listitem">
                            <a asp-controller="Modules" asp-action="Index" class="nav-link">
                                <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
                                <span>Modules</span>
                            </a>
                        </li>
                    }

                </ul>
            </nav>

            @* ── Sidebar Footer: theme switcher + logout ──────────────────── *@
            <div class="sidebar-footer">

                @* Theme switcher – three-button pill *@
                <div class="theme-switcher" aria-label="Switch colour theme">
                    <button class="theme-btn" data-theme="dark"  title="Dark"  aria-label="Dark theme">
                        <i class="bi bi-moon-stars-fill" aria-hidden="true"></i>
                    </button>
                    <button class="theme-btn" data-theme="light" title="Light" aria-label="Light theme">
                        <i class="bi bi-sun-fill" aria-hidden="true"></i>
                    </button>
                    <button class="theme-btn" data-theme="sepia" title="Sepia" aria-label="Sepia theme">
                        <i class="bi bi-book-fill" aria-hidden="true"></i>
                    </button>
                </div>

                @* Logout – POST form for CSRF safety *@
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn" aria-label="Sign out">
                        <i class="bi bi-box-arrow-left" aria-hidden="true"></i>
                        <span>Logout</span>
                    </button>
                </form>

            </div>
        </aside>

        @* ════════════════════════════════════════════════════════════════════
           RIGHT BODY  –  everything to the right of the sidebar
           ════════════════════════════════════════════════════════════════════ *@
        <div class="l-body">

            @* ── Top Header: mobile toggle + page title + role badge ──────── *@
            <header class="l-topbar" role="banner">

                @* Mobile hamburger – opens sidebar overlay *@
                <button class="l-sidebar-toggle d-lg-none"
                        id="sidebarOpen"
                        aria-label="Open navigation"
                        aria-expanded="false"
                        aria-controls="sidebar">
                    <i class="bi bi-list" aria-hidden="true"></i>
                </button>

                @* Current page title *@
                <h1 class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</h1>

                @* Spacer pushes role badge to the right *@
                <div class="topbar-spacer" aria-hidden="true"></div>

                @* Active role badge *@
                <span class="badge-role" aria-label="Your role">
                    @string.Join(" | ", currentUser.Roles)
                </span>

            </header>

            @* ── Main Content: flash alerts + routed page body ────────────── *@
            <main class="l-content" id="main-content" role="main">

                @* Success / error flash messages (auto-dismiss after 4 s) *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show"
                         role="alert" aria-live="polite">
                        <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>
                        @TempData["Success"]
                        <button type="button" class="btn-close"
                                data-bs-dismiss="alert"
                                aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show"
                         role="alert" aria-live="assertive">
                        <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                        @TempData["Error"]
                        <button type="button" class="btn-close"
                                data-bs-dismiss="alert"
                                aria-label="Close"></button>
                    </div>
                }

                @* Injected page view *@
                @RenderBody()

            </main>

            @* ── Footer: copyright + version info ─────────────────────────── *@
            <footer class="l-footer" role="contentinfo">
                <span>&copy; @DateTime.UtcNow.Year UserHub</span>
                <span class="l-footer-sep" aria-hidden="true">·</span>
                <span>ASP.NET Core 8</span>
                <span class="l-footer-sep" aria-hidden="true">·</span>
                <span>v1.0.0</span>
            </footer>

        </div>
        @* end .l-body *@

    </div>
    @* end .layout-shell *@

    @* Mobile sidebar backdrop overlay *@
    <div class="l-sidebar-overlay" id="overlay" aria-hidden="true"></div>
}
else
{
    @* ── Unauthenticated: render login / access-denied page only ─────────── *@
    @RenderBody()
}

@* ── Vendor JS ──────────────────────────────────────────────────────────── *@
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@* Application JS (sidebar, theme switcher, alerts, confirm) *@
<script src="~/js/site.js" asp-append-version="true"></script>

@* Page-specific scripts injected by child views *@
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
