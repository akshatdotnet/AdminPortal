@model UserManagement.ViewModels.UserCreateEditViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit User" : "Add User";
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-@(isEdit ? "pencil-square" : "person-plus") me-2 text-accent"></i>
            @ViewData["Title"]
        </h1>
        <div class="sub">@(isEdit ? $"Editing: {Model.FullName}" : "Create a new system user")</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"
         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <div class="row g-3">
        <!-- Left: User Info -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-person-badge me-2"></i>User Information
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                            <span asp-validation-for="FullName" class="field-validation-error"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Username" class="form-label"></label>
                            <input asp-for="Username" class="form-control" placeholder="johndoe" />
                            <span asp-validation-for="Username" class="field-validation-error"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" type="email" class="form-control"
                                   placeholder="john@example.com" />
                            <span asp-validation-for="Email" class="field-validation-error"></span>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">
                                Password
                                @if (isEdit)
                                {
                                    <span class="text-muted" style="font-size:11px;font-weight:400">
                                        (leave blank to keep)
                                    </span>
                                }
                            </label>
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="@(isEdit ? "Leave blank to keep current" : "Minimum 6 characters")" />
                            <span asp-validation-for="Password" class="field-validation-error"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control"
                                   placeholder="Repeat password" />
                            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input"
                                       type="checkbox" role="switch" />
                                <label asp-for="IsActive" class="form-check-label">
                                    Active (user can log in)
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Roles -->
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-shield-check me-2"></i>Assign Roles
                </div>
                <div class="card-body">
                    @if (!Model.AvailableRoles.Any())
                    {
                        <p class="text-muted" style="font-size:13px">
                            No roles available.
                            <a asp-controller="Roles" asp-action="Create">Create a role</a> first.
                        </p>
                    }
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <div class="perm-row">
                            <div class="form-check">
                                <input type="checkbox"
                                       name="SelectedRoleIds"
                                       value="@role.Id"
                                       class="form-check-input"
                                       id="role_@role.Id"
                                       @(role.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="role_@role.Id"
                                       style="font-weight:600;cursor:pointer">
                                    @role.Name
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2 me-1"></i>@(isEdit ? "Update User" : "Create User")
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
